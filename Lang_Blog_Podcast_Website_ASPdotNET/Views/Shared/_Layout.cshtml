<!DOCTYPE html>
<html lang="vi">

@* ======================================================================================================================================================== *@
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* Thiết lập tiêu đề động kết hợp với tên thương hiệu LẶNG. *@
    <title>@ViewData["Title"] LẶNG.</title>

    @* Tối ưu hóa tốc độ tải font từ Google Fonts bằng cách kết nối sớm (Preconnect) *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Playfair+Display+SC&family=Montserrat:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" data-layout-style="true">

    @* Nhúng file CSS chính của trang web, tự động tạo chuỗi định danh phiên bản (v=...) để tránh lỗi bộ nhớ đệm (Cache) *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" data-layout-style="true" />
    <link rel="stylesheet" href="~/css/GlobalPlayer.css" asp-append-version="true" data-layout-style="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" data-layout-style="true" />
    @* Cấu hình ảnh biểu tượng thu nhỏ (Favicon) hiển thị trên tab trình duyệt *@
    <link rel="icon"
          type="image/png"
          href="~/images/Logo/logo_website.png" />
    @await RenderSectionAsync("Styles", required: false)

    <!-- THÊM DÒNG NÀY VÀO ĐÂY -->
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" data-layout-style="true" />
</head>
@* ======================================================================================================================================================== *@




@* ======================================================================================================================================================== *@
<body>
    @{
        var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
        var headerClass = "header-theme-default";
        
        if (controllerName == "Podcast") {
            headerClass = "header-theme-dark";
        } else if (controllerName == "Story") {
            headerClass = "header-theme-light";
        } else if (controllerName == "Magazine") {
            headerClass = "header-theme-avant";
        }
    }
    @* =================================HEADER==============================================(Phần Đầu Trang) *@
    <header class="main-header @headerClass">
        <div class="header-container">
            @* Logo dạng chữ, khi bấm vào sẽ dẫn về trang chủ *@
            <a class="logo-text" asp-area="" asp-controller="Home" asp-action="Index">LẶNG.</a>

            @* Thanh điều hướng chính của website kết nối tới các Controller tương ứng *@
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">TRANG CHỦ</a>
                <a asp-controller="Story" asp-action="Index">CÂU CHUYỆN</a>
                <a asp-controller="Magazine" asp-action="Index">TẠP CHÍ</a>
                <a asp-controller="Podcast" asp-action="Index">PODCAST</a>
                <a asp-controller="Home" asp-action="About">VỀ LẶNG</a>

                @* Kiểm tra bảo mật: Nếu Người dùng đã đăng nhập VÀ tài khoản thuộc nhóm quyền "Admin" thì mới hiển thị lối tắt *@
                @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index">BAN BIÊN TẬP</a>
                }
            </nav>

            @* Góc bên phải của thanh Header: Nơi chứa khu vực tài khoản thành viên *@
            <div class="header-right">
                @* Nhúng View thành phần chứa logic Đăng nhập/Đăng xuất/Hồ sơ người dùng *@
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    @* =================================MAIN==============================================(Phần Giữa Trang) *@
    @* Nơi các View con của từng trang cụ thể (Index, About,...) sẽ được lồng vào và render tại đây *@
    <main role="main" class="main-content">
        @RenderBody()
    </main>

    @* =================================FOOTER==============================================(Phần Đuôi Trang) *@
    <footer class="site-footer @(headerClass.Replace("header-", "footer-"))">
        <div class="footer-top-border"></div>
        <div class="footer-container">

            @* Cột 1: Thông tin thương hiệu, Slogan và mạng xã hội *@
            <div class="footer-brand">
                <h2 class="logo-text-footer">LẶNG.</h2>
                <p class="footer-slogan">"Nơi những tâm hồn tìm thấy nhau trong sự tĩnh lặng của ngôn từ."</p>
                <div class="social-links">
                    <a href="https://www.facebook.com/minh.nhat.65912/">FB</a>
                    <a href="https://www.threads.com/chao_em_hehe">TH</a>
                    <a href="https://x.com/MinhNhat291025">X</a>
                    @* <a href="#">BE</a> *@
                </div>
            </div>

            @* Cột 2: Các liên kết khám phá nhanh nội dung *@
            <div class="footer-links">
                <h4 class="footer-heading">KHÁM PHÁ</h4>
                <ul>
                    <li><a asp-controller="Story" asp-action="Index">CÂU CHUYỆN</a></li>
                    <li><a asp-controller="Magazine" asp-action="Index">TẠP CHÍ</a></li>
                    <li> <a asp-controller="Podcast" asp-action="Index">PODCAST</a></li>
                </ul>
            </div>


           
            @* Cột 3: Các liên kết liên hệ và tương tác hành động *@
            <div class="footer-links">
                <h4 class="footer-heading">KẾT NỐI</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="About">Về Chúng Tôi</a></li>
                   
                    <li class="email"> <p>BUIMINHNHAT2910@GMAIL.COM</p> </li>

                </ul>
            </div>

        </div>

        @* Bản quyền và nút cuộn lên đầu trang *@
        <div class="footer-bottom">
            <span class="copyright">&copy; 2026 LẶNG. MEDIA </span>
            <a href="#" class="back-to-top">VỀ ĐẦU TRANG &uarr;</a>
            <span class="creator-credit" style="display: block; font-size: 8px; margin-top: 8px; color: #888;">
                Cre By: Bùi Minh Nhật
            </span>
        </div>
    </footer>

    @* =================================GLOBAL AUDIO PLAYER================================== *@
    <div class="lang-global-player" id="lang-global-player">
        <audio id="gp-audio" preload="metadata"></audio>

        @* --- Cột trái: Ảnh bìa + Thông tin bài --- *@
        <div class="gp-left">
            <img id="gp-cover" class="gp-cover" src="" alt="" />
            <div class="gp-track-info">
                <span id="gp-title" class="gp-track-title">—</span>
                <span id="gp-author" class="gp-track-author">—</span>
            </div>
        </div>

        @* --- Cột giữa: Điều khiển + Thanh tiến trình --- *@
        <div class="gp-center">
            <div class="gp-controls">
                <button class="gp-btn gp-btn-skip" id="gp-btn-skip-back" title="Tua lùi 15s">
                    <i class="fa-solid fa-backward"></i>
                </button>
                <button class="gp-btn gp-btn-play" id="gp-btn-play" title="Phát / Tạm dừng">
                    <i class="fa-solid fa-play" style="transform: translateX(1px);"></i>
                </button>
                <button class="gp-btn gp-btn-skip" id="gp-btn-skip-forward" title="Tua tiến 15s">
                    <i class="fa-solid fa-forward"></i>
                </button>
            </div>
            <div class="gp-progress-row">
                <span class="gp-time" id="gp-time-current">0:00</span>
                <div class="gp-seekbar-container" id="gp-seekbar">
                    <div class="gp-seekbar-track">
                        <div class="gp-seekbar-fill" id="gp-seekbar-fill"></div>
                    </div>
                </div>
                <span class="gp-time" id="gp-time-total">0:00</span>
            </div>
        </div>

        @* --- Cột phải: Volume + Speed + Đóng --- *@
        <div class="gp-right">
            <button class="gp-btn gp-speed-btn" id="gp-speed-btn" title="Tốc độ phát">1x</button>
            <div class="gp-volume-group">
                <button class="gp-btn" id="gp-volume-btn" title="Tắt/Bật âm">
                    <i class="fa-solid fa-volume-high"></i>
                </button>
                <div class="gp-volume-slider-container" id="gp-volume-slider">
                    <div class="gp-volume-track">
                        <div class="gp-volume-fill" id="gp-volume-fill"></div>
                    </div>
                </div>
            </div>
            <button class="gp-btn gp-btn-close" id="gp-btn-close" title="Đóng player">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>

    @* =================================JAVASCRIPT=========================================== *@
    <script data-layout-script="true">
            (function () {
                // Lắng nghe sự kiện click chuột trên toàn bộ tài liệu (Document)
                document.addEventListener('click', function (e) {
                    // Kiểm tra xem vị trí click có thuộc nút menu người dùng (.user-menu-btn) hay không
                    var btn = e.target.closest('.user-menu-btn');
                    // Tìm kiếm menu dropdown nào hiện tại đang được mở (aria-hidden="false")
                    var open = document.querySelector('.user-dropdown[aria-hidden="false"]');

                    // Trường hợp 1: Người dùng nhấn trực tiếp vào nút mở menu tài khoản
                    if (btn) {
                        var container = btn.closest('.header-user');
                        if (!container) return;
                        var menu = container.querySelector('.user-dropdown');
                        var expanded = btn.getAttribute('aria-expanded') === 'true';

                        // Đảo ngược trạng thái thuộc tính aria-expanded (true <-> false) để phục vụ hỗ trợ đọc màn hình
                        btn.setAttribute('aria-expanded', (!expanded).toString());

                        if (expanded) {
                            // Nếu menu đang mở thì ẩn đi
                            menu.setAttribute('aria-hidden', 'true');
                        } else {
                            // Nếu đang có một menu khác mở trên màn hình thì tự động đóng menu cũ lại trước
                            if (open && open !== menu) {
                                open.setAttribute('aria-hidden', 'true');
                                if (open.previousElementSibling) open.previousElementSibling.setAttribute('aria-expanded', 'false');
                            }
                            // Hiển thị menu dropdown hiện tại lên
                            menu.setAttribute('aria-hidden', 'false');
                        }
                        return;
                    }

                    // Trường hợp 2: Người dùng nhấn chuột ra vùng ngoài (không thuộc khối .header-user), tự động đóng menu đang mở
                    if (open && !e.target.closest('.header-user')) {
                        open.setAttribute('aria-hidden', 'true');
                        if (open.previousElementSibling) open.previousElementSibling.setAttribute('aria-expanded', 'false');
                    }
                });

                // Lắng nghe sự kiện nhấn phím trên bàn phím
                document.addEventListener('keydown', function (e) {
                    // Nếu người dùng nhấn phím Escape (ESC) trên bàn phím, tiến hành đóng menu dropdown lập tức
                    if (e.key === 'Escape' || e.key === 'Esc') {
                        var open = document.querySelector('.user-dropdown[aria-hidden="false"]');
                        if (open) {
                            open.setAttribute('aria-hidden', 'true');
                            if (open.previousElementSibling) open.previousElementSibling.setAttribute('aria-expanded', 'false');
                        }
                    }
                });
            })();
    </script>
    <script data-layout-script="true">
document.addEventListener('DOMContentLoaded', function() {
    const bellBtn = document.getElementById('bell-btn-toggle');
    const notifDropdown = document.getElementById('notif-dropdown');
    const notifBadge = document.getElementById('notif-badge');
    const notifList = document.getElementById('notif-list');
    const markAllReadBtn = document.getElementById('mark-all-read-btn');
    
    if (!bellBtn) return; // User not logged in

    // Toggle dropdown
    bellBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        notifDropdown.classList.toggle('show');
        if (notifDropdown.classList.contains('show')) {
            loadRecentNotifs();
        }
    });

    // Close when clicking outside
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.notification-bell') && notifDropdown.classList.contains('show')) {
            notifDropdown.classList.remove('show');
        }
    });

    // Load unread count
    function loadUnreadCount() {
        fetch('/Notification/GetUnreadCount')
            .then(r => r.json())
            .then(data => {
                if (data.count > 0) {
                    notifBadge.style.display = 'flex';
                    notifBadge.innerText = data.count > 99 ? '99+' : data.count;
                } else {
                    notifBadge.style.display = 'none';
                }
            }).catch(() => {});
    }

    // Load recent notifications
    function loadRecentNotifs() {
        notifList.innerHTML = '<div class="notif-loading" style="padding:15px; text-align:center; color:#888;">Đang tải...</div>';
        fetch('/Notification/GetRecent')
            .then(r => r.json())
            .then(data => {
                if (data.length === 0) {
                    notifList.innerHTML = '<div style="padding:15px; text-align:center; color:#888; font-size:13px;">Không có thông báo nào</div>';
                    return;
                }
                let html = '';
                data.forEach(n => {
                    let icon = '<i class="fa-solid fa-circle-info" style="color:#258cfb"></i>';
                    if(n.type === 'Approved') icon = '<i class="fa-solid fa-circle-check" style="color:#2e7d32"></i>';
                    if(n.type === 'Rejected') icon = '<i class="fa-solid fa-circle-xmark" style="color:#c62828"></i>';
                    
                    html += `<a href="${n.linkUrl || '#'}" class="notif-item ${n.isRead ? '' : 'unread'}" data-id="${n.id}">
                        <div class="notif-icon">${icon}</div>
                        <div class="notif-content">
                            <div class="notif-title">${n.title}</div>
                            <div class="notif-desc">${n.message || ''}</div>
                            <div class="notif-time">${n.createdAt}</div>
                        </div>
                    </a>`;
                });
                notifList.innerHTML = html;

                // Add click listener to mark read
                notifList.querySelectorAll('.notif-item.unread').forEach(item => {
                    item.addEventListener('click', function() {
                        let id = this.getAttribute('data-id');
                        fetch('/Notification/MarkAsRead?id=' + id, { method: 'POST' }).then(() => {
                            loadUnreadCount();
                        });
                    });
                });
            }).catch(() => {
                notifList.innerHTML = '<div style="padding:15px; text-align:center; color:red; font-size:13px;">Lỗi tải thông báo</div>';
            });
    }

    // Mark all as read
    if (markAllReadBtn) {
        markAllReadBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            fetch('/Notification/MarkAllAsRead', { 
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).then(r => r.json())
              .then(data => {
                  if(data.success) {
                      loadUnreadCount();
                      loadRecentNotifs();
                  }
              });
        });
    }

    // Initial load & Polling every 60s
    loadUnreadCount();
    setInterval(loadUnreadCount, 60000);
});
</script>
    <!-- Gọi thư viện AOS và SweetAlert dùng chung cho toàn web -->
    <script src="https://unpkg.com/aos@next/dist/aos.js" data-layout-script="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" data-layout-script="true"></script>

    <script src="~/js/GlobalPlayer.js" asp-append-version="true" data-layout-script="true"></script>
    <script src="~/js/spa-router.js" asp-append-version="true" data-layout-script="true"></script>
    @* Vùng cho phép các View con nhúng bổ sung các đoạn mã Script riêng lẻ vào cuối trang Layout *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
@* ======================================================================================================================================================== *@
</html>