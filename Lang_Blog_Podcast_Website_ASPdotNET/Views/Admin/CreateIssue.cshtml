@model Lang_Blog_Podcast_Website_ASPdotNET.Models.MagazineIssue

@{
    ViewData["Title"] = "Tạo Ấn Phẩm Tạp Chí";
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="~/css/Admin/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/CreateIssue.css" asp-append-version="true" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
@* ======================================================================================================================================================== *@



@* ======================================================================================================================================================== *@
<div class="admin-container admin-layout" style="background-color: #f9f9f9; min-height: 100vh;">
    <main class="admin-main" style="margin-left: 0; width: 100%;">
        <div class="form-container">
            <h2 class="form-title">@ViewData["Title"]</h2>
            <p class="form-subtitle"><i class="fa-solid fa-wand-magic-sparkles"></i> Khởi tạo một ấn phẩm mới ở trạng thái <strong>Nháp</strong>. Sau khi thêm đủ bài viết, bạn có thể Xuất bản từ trang quản lý.</p>

            <div class="tip-box">
                <i class="fa-solid fa-lightbulb"></i>
                <strong>Mẹo:</strong> Nên chọn tên ấn phẩm ngắn gọn, gợi cảm xúc (tối đa 40 ký tự). Ảnh bìa nên có tỉ lệ 3:4 hoặc 4:5 để hiển thị đẹp nhất.
            </div>

            <form asp-action="CreateIssue" method="post" enctype="multipart/form-data" id="createIssueForm">

                <div class="form-row-2col">
                    <div class="form-group">
                        <label asp-for="IssueNumber"><i class="fa-solid fa-hashtag"></i> Số phát hành</label>
                        <input asp-for="IssueNumber" class="form-control" placeholder="VD: V.01" maxlength="10" id="inputIssueNumber" />
                        <span class="char-counter" id="counterIssueNumber">0 / 10</span>
                        <span asp-validation-for="IssueNumber" class="validation-msg"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Season"><i class="fa-solid fa-sun"></i> Kỳ / Mùa</label>
                        <input asp-for="Season" class="form-control" placeholder="VD: SUMMER 2026" maxlength="30" id="inputSeason" />
                        <span class="char-counter" id="counterSeason">0 / 30</span>
                        <span asp-validation-for="Season" class="validation-msg"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Title"><i class="fa-solid fa-feather-pointed"></i> Tên ấn phẩm</label>
                    <input asp-for="Title" class="form-control" placeholder="VD: Mùa Hạ Tĩnh Lặng" maxlength="40" id="inputTitle" />
                    <span class="char-counter" id="counterTitle">0 / 40</span>
                    <span asp-validation-for="Title" class="validation-msg"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description"><i class="fa-solid fa-align-left"></i> Mô tả / Lời tựa</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn về ấn phẩm này..." maxlength="500" id="inputDescription"></textarea>
                    <span class="char-counter" id="counterDescription">0 / 500</span>
                    <span asp-validation-for="Description" class="validation-msg"></span>
                </div>

                <div class="form-group">
                    <label><i class="fa-solid fa-image"></i> Ảnh Bìa (Cover Image)</label>
                    <div class="file-upload-area" id="fileUploadArea">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <p><strong>Nhấn để chọn</strong> hoặc kéo thả ảnh bìa vào đây</p>
                        <p style="font-size: 11px; margin-top: 4px; color: #bbb;">Hỗ trợ: JPG, PNG, WEBP — Khuyến nghị tỉ lệ 3:4</p>
                        <input type="file" name="coverImage" accept="image/*" id="coverImageInput" />
                    </div>
                    <div class="cover-preview" id="coverPreview">
                        <img id="coverPreviewImg" src="" alt="Preview ảnh bìa" />
                        <div class="file-name" id="coverFileName"></div>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 40px;">
                    <button type="submit" class="btn-submit" id="btnSubmit">
                        <i class="fa-solid fa-plus"></i> TẠO ẤN PHẨM MỚI (NHÁP)
                    </button>
                </div>
                
                <div class="text-center" style="text-align: center;">
                    <a href="/Admin#magazine" class="back-link"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách quản lý</a>
                </div>
            </form>
        </div>
    </main>
</div>
@* ======================================================================================================================================================== *@



@* ======================================================================================================================================================== *@
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // =========================================================================
        // 1. BỘ ĐẾM KÝ TỰ REAL-TIME
        // =========================================================================
        function setupCharCounter(inputId, counterId, maxLen) {
            var input = document.getElementById(inputId);
            var counter = document.getElementById(counterId);
            if (!input || !counter) return;

            function update() {
                var len = input.value.length;
                counter.textContent = len + ' / ' + maxLen;
                counter.classList.remove('warning', 'danger');
                if (len >= maxLen) {
                    counter.classList.add('danger');
                } else if (len >= maxLen * 0.8) {
                    counter.classList.add('warning');
                }
            }
            input.addEventListener('input', update);
            update(); // Run once on load (for form repopulation)
        }

        setupCharCounter('inputIssueNumber', 'counterIssueNumber', 10);
        setupCharCounter('inputTitle', 'counterTitle', 40);
        setupCharCounter('inputDescription', 'counterDescription', 500);
        setupCharCounter('inputSeason', 'counterSeason', 30);

        // =========================================================================
        // 2. PREVIEW ẢNH BÌA
        // =========================================================================
        var coverInput = document.getElementById('coverImageInput');
        var coverPreview = document.getElementById('coverPreview');
        var coverPreviewImg = document.getElementById('coverPreviewImg');
        var coverFileName = document.getElementById('coverFileName');
        var fileUploadArea = document.getElementById('fileUploadArea');

        if (coverInput) {
            coverInput.addEventListener('change', function () {
                if (this.files && this.files[0]) {
                    var file = this.files[0];

                    // Kiểm tra loại file
                    if (!file.type.match('image.*')) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Định dạng không hỗ trợ',
                            text: 'Vui lòng chọn file ảnh (JPG, PNG, WEBP)!',
                            confirmButtonColor: '#B29B84'
                        });
                        this.value = '';
                        return;
                    }

                    // Kiểm tra kích thước (tối đa 5MB)
                    if (file.size > 5 * 1024 * 1024) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'File quá lớn',
                            text: 'Ảnh bìa không được vượt quá 5MB!',
                            confirmButtonColor: '#B29B84'
                        });
                        this.value = '';
                        return;
                    }

                    var reader = new FileReader();
                    reader.onload = function (e) {
                        coverPreviewImg.src = e.target.result;
                        coverPreview.style.display = 'block';
                        coverFileName.innerHTML = '<i class="fa-solid fa-check-circle" style="color: #27ae60;"></i> ' + file.name;
                        fileUploadArea.classList.add('has-file');
                    };
                    reader.readAsDataURL(file);
                } else {
                    coverPreview.style.display = 'none';
                    fileUploadArea.classList.remove('has-file');
                }
            });
        }

        // =========================================================================
        // 3. XỬ LÝ FORM SUBMIT — CHẶN TRƯỚC KHI GỬI NẾU THIẾU ẢNH
        // =========================================================================
        var form = document.getElementById('createIssueForm');
        if (form) {
            form.addEventListener('submit', function (e) {
                var imgInput = document.getElementById('coverImageInput');
                if (!imgInput || !imgInput.files || imgInput.files.length === 0) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'error',
                        title: 'Thiếu ảnh bìa!',
                        html: 'Bạn cần chọn ảnh bìa trước khi tạo ấn phẩm.<br><small style="color:#999;">Nhấn vào khung "Kéo thả ảnh" để chọn file.</small>',
                        confirmButtonColor: '#111',
                        confirmButtonText: 'Đã hiểu'
                    });
                    return false;
                }
            });
        }

        // =========================================================================
        // 4. THÔNG BÁO SWEETALERT2 TỪ SERVER (TempData)
        // =========================================================================
        document.addEventListener("DOMContentLoaded", function () {

             @if (TempData["AdminMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    html: @Html.Raw(Json.Serialize(TempData["AdminMessage"])),
                    confirmButtonColor: '#111',
                    confirmButtonText: 'Quay về Trang quản lý',
                    allowOutsideClick: false,
                    timer: 4000,
                    timerProgressBar: true
                }).then(function () {
                    window.location.href = '/Admin#magazine';
                });
                </text>
            }

            @if (TempData["AdminError"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Có lỗi xảy ra!',
                    html: @Html.Raw(Json.Serialize(TempData["AdminError"])),
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: 'Tôi sẽ kiểm tra lại'
                });
                </text>
            }
        });
    </script>
}
@* ======================================================================================================================================================== *@