@model Lang_Blog_Podcast_Website_ASPdotNET.Models.MagazineArticle

@{
    ViewData["Title"] = "[Preview] " + Model.Title;
}
@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Magazine/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/PreviewArticle.css" asp-append-version="true" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="lang-magazine-avant-container" style="background-color: #f9f9f9; padding-bottom: 50px;">
    
    <div class="preview-badge"><i class="fa-solid fa-eye"></i> CHẾ ĐỘ XEM TRƯỚC (PREVIEW)</div>

    <div class="article-header" data-aos="fade-in">
        <div class="article-header-bg" style="background-image: url('@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/default-cover.jpg" : Model.ImagePath)');"></div>
        <div class="article-header-content">
            <div class="article-category" data-aos="fade-up" data-aos-delay="200">
                LẶNG. MAGAZINE / @(Model.Category?.Name ?? "Tạp Chí")
            </div>
            <h1 class="article-title" data-aos="fade-up" data-aos-delay="400">@Model.Title</h1>
            <div class="article-meta" data-aos="fade-up" data-aos-delay="600">
                <span><i class="fa-regular fa-clock"></i> @Model.CreatedAt.ToString("dd MMMM, yyyy")</span>
                <span><i class="fa-solid fa-hashtag"></i> Thuộc Ấn Phẩm: @(Model.Issue?.IssueNumber ?? "N/A")</span>
                <span><i class="fa-regular fa-eye"></i> Bản Nháp</span>
            </div>
        </div>
    </div>

    <main class="article-body" data-aos="fade-up" data-aos-delay="800">
        <div class="article-content-wrapper" id="articleContent">
            @Html.Raw(Model.Content)
        </div>

        <div class="read-more-trigger-wrapper" id="readMoreWrapper" style="display: none;">
            <div class="read-more-overlay"></div>
            <button class="read-more-btn" id="readMoreBtn">Xem Thêm ở Cuối Bài <i class="fa-solid fa-chevron-down"></i></button>
        </div>

        <div style="margin-top: 80px; border-top: 1px solid #ddd; padding-top: 40px; text-align: center;">
            <a href="/Admin/PreviewIssue/@Model.IssueId" class="btn outline" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 2px; padding: 12px 30px; text-decoration: none; color: #111;">
                &larr; TRỞ VỀ PREVIEW ẤN PHẨM @(Model.Issue?.IssueNumber)
            </a>
        </div>
    </main>
</div>
@* ======================================================================================================================================================== *@



@* ======================================================================================================================================================== *@
@section Scripts {
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({
            once: true,
            offset: 50,
            easing: 'ease-out-cubic',
            duration: 1200
        });

        // Script Xem Thêm - Thu Gọn bài viết trên 100 dòng
        document.addEventListener("DOMContentLoaded", function() {
            const contentEl = document.getElementById('articleContent');
            const readMoreWrapper = document.getElementById('readMoreWrapper');
            const readMoreBtn = document.getElementById('readMoreBtn');
            const overlay = document.querySelector('.read-more-overlay');
            
            if (contentEl) {
                const style = window.getComputedStyle(contentEl);
                const lineHeight = parseFloat(style.lineHeight) || 36; // 36px mặc định nếu line-height: 2 cho font 18px
                const maxAllowedHeight = lineHeight * 100; // Chiều cao tối đa cho 100 dòng
                
                if (contentEl.scrollHeight > maxAllowedHeight) {
                    contentEl.classList.add('collapsed');
                    contentEl.style.maxHeight = maxAllowedHeight + 'px';
                    readMoreWrapper.style.display = 'block';
                    
                    readMoreBtn.addEventListener('click', function() {
                        if (contentEl.classList.contains('collapsed')) {
                            contentEl.classList.remove('collapsed');
                            contentEl.style.maxHeight = contentEl.scrollHeight + 'px';
                            readMoreBtn.innerHTML = 'Thu Gọn Bài Viết <i class="fa-solid fa-chevron-up"></i>';
                            overlay.style.display = 'none';
                            readMoreWrapper.style.marginTop = '20px';
                            readMoreWrapper.style.paddingTop = '0';
                        } else {
                            contentEl.classList.add('collapsed');
                            contentEl.style.maxHeight = maxAllowedHeight + 'px';
                            readMoreBtn.innerHTML = 'Xem Thêm ở Cuối Bài <i class="fa-solid fa-chevron-down"></i>';
                            overlay.style.display = 'block';
                            readMoreWrapper.style.marginTop = '-120px';
                            readMoreWrapper.style.paddingTop = '140px';
                            
                            // Cuộn mượt về khu vực nút bấm để giữ tiêu điểm
                            contentEl.scrollIntoView({ behavior: 'smooth', block: 'end' });
                        }
                    });
                }
            }
        });
    </script>
}
@* ======================================================================================================================================================== *@