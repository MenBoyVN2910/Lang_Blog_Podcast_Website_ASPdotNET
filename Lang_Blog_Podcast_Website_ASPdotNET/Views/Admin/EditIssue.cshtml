@model Lang_Blog_Podcast_Website_ASPdotNET.Models.MagazineIssue

@{
    ViewData["Title"] = "Chỉnh Sửa Ấn Phẩm";
}

<link rel="stylesheet" href="~/css/Admin/Index.css" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    .form-container {
        background: #fff;
        padding: 48px;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.06);
        max-width: 820px;
        margin: 40px auto;
        font-family: 'Plus Jakarta Sans', sans-serif;
        position: relative;
        overflow: hidden;
    }
    .form-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #B29B84, #8C7B6B, #B29B84);
    }
    .form-title {
        font-family: 'Playfair Display', serif;
        font-size: 32px;
        color: #111;
        margin-bottom: 8px;
    }
    .form-subtitle {
        color: #999;
        font-size: 14px;
        margin-bottom: 35px;
        padding-bottom: 20px;
        border-bottom: 1px solid #f0f0f0;
    }
    .form-group {
        margin-bottom: 24px;
        position: relative;
    }
    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
        color: #333;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        font-family: inherit;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #fafafa;
        box-sizing: border-box;
    }
    .form-control:focus {
        border-color: #B29B84;
        box-shadow: 0 0 0 4px rgba(178, 155, 132, 0.12);
        outline: none;
        background: #fff;
    }
    .form-control.is-invalid {
        border-color: #dc3545;
        box-shadow: 0 0 0 4px rgba(220, 53, 69, 0.08);
    }
    .char-counter {
        position: absolute;
        right: 4px;
        bottom: -20px;
        font-size: 11px;
        color: #aaa;
        font-weight: 500;
        transition: color 0.3s;
    }
    .char-counter.warning {
        color: #e67e22;
        font-weight: 600;
    }
    .char-counter.danger {
        color: #dc3545;
        font-weight: 700;
    }
    .validation-msg {
        font-size: 12px;
        color: #dc3545;
        margin-top: 6px;
        display: block;
        min-height: 18px;
    }

    /* === FILE UPLOAD === */
    .file-upload-area {
        border: 2px dashed #ddd;
        border-radius: 12px;
        padding: 30px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background: #fcfcfc;
        position: relative;
    }
    .file-upload-area:hover {
        border-color: #B29B84;
        background: rgba(178, 155, 132, 0.03);
    }
    .file-upload-area.has-file {
        border-color: #B29B84;
        border-style: solid;
        background: rgba(178, 155, 132, 0.04);
    }
    .file-upload-area i {
        font-size: 28px;
        color: #ccc;
        margin-bottom: 8px;
        transition: color 0.3s;
    }
    .file-upload-area:hover i {
        color: #B29B84;
    }
    .file-upload-area p {
        color: #999;
        font-size: 13px;
        margin: 0;
    }
    .file-upload-area p strong {
        color: #B29B84;
    }
    .file-upload-area input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }
    .cover-preview {
        margin-top: 16px;
        text-align: center;
    }
    .cover-preview img {
        max-width: 100%;
        max-height: 220px;
        border-radius: 10px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        border: 3px solid #fff;
    }
    .cover-preview .file-name {
        font-size: 12px;
        color: #888;
        margin-top: 8px;
    }

    /* === BUTTONS === */
    .btn-submit {
        background: linear-gradient(135deg, #111 0%, #333 100%);
        color: #fff;
        border: none;
        padding: 16px;
        width: 100%;
        border-radius: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.4s ease;
        text-transform: uppercase;
        position: relative;
        overflow: hidden;
    }
    .btn-submit::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        transition: left 0.6s;
    }
    .btn-submit:hover {
        background: linear-gradient(135deg, #B29B84 0%, #8C7B6B 100%);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(178, 155, 132, 0.3);
    }
    .btn-submit:hover::after {
        left: 100%;
    }
    .btn-submit:active {
        transform: translateY(0);
    }
    .back-link {
        display: inline-block;
        margin-top: 20px;
        color: #888;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: color 0.3s;
    }
    .back-link:hover {
        color: #111;
    }

    /* === LAYOUT === */
    .form-row-2col {
        display: flex;
        gap: 20px;
    }
    .form-row-2col > .form-group {
        flex: 1;
    }
</style>

<div class="admin-container admin-layout" style="background-color: #f9f9f9; min-height: 100vh;">
    <main class="admin-main" style="margin-left: 0; width: 100%;">
        <div class="form-container">
            <h2 class="form-title">@ViewData["Title"]</h2>
            <p class="form-subtitle"><i class="fa-solid fa-pen"></i> Chỉnh sửa thông tin ấn phẩm. Bạn có thể tải lên ảnh mới để thay thế ảnh cũ.</p>

            <form asp-action="EditIssue" method="post" enctype="multipart/form-data" id="editIssueForm">
                <input type="hidden" asp-for="Id" />

                <div class="form-row-2col">
                    <div class="form-group">
                        <label asp-for="IssueNumber"><i class="fa-solid fa-hashtag"></i> Số phát hành</label>
                        <input asp-for="IssueNumber" class="form-control" placeholder="VD: V.01" maxlength="10" id="inputIssueNumber" />
                        <span class="char-counter" id="counterIssueNumber">0 / 10</span>
                        <span asp-validation-for="IssueNumber" class="validation-msg"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Season"><i class="fa-solid fa-sun"></i> Kỳ / Mùa</label>
                        <input asp-for="Season" class="form-control" placeholder="VD: SUMMER 2026" maxlength="30" id="inputSeason" />
                        <span class="char-counter" id="counterSeason">0 / 30</span>
                        <span asp-validation-for="Season" class="validation-msg"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Title"><i class="fa-solid fa-feather-pointed"></i> Tên ấn phẩm</label>
                    <input asp-for="Title" class="form-control" placeholder="VD: Mùa Hạ Tĩnh Lặng" maxlength="40" id="inputTitle" />
                    <span class="char-counter" id="counterTitle">0 / 40</span>
                    <span asp-validation-for="Title" class="validation-msg"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description"><i class="fa-solid fa-align-left"></i> Mô tả / Lời tựa</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn về ấn phẩm này..." maxlength="500" id="inputDescription"></textarea>
                    <span class="char-counter" id="counterDescription">0 / 500</span>
                    <span asp-validation-for="Description" class="validation-msg"></span>
                </div>

                <div class="form-group">
                    <label><i class="fa-solid fa-image"></i> Ảnh Bìa (Cover Image)</label>
                    <div class="file-upload-area" id="fileUploadArea">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <p><strong>Nhấn để chọn</strong> ảnh mới nếu muốn thay thế ảnh cũ</p>
                        <p style="font-size: 11px; margin-top: 4px; color: #bbb;">Hỗ trợ: JPG, PNG, WEBP — Khuyến nghị tỉ lệ 3:4</p>
                        <input type="file" name="coverImage" accept="image/*" id="coverImageInput" />
                    </div>
                    <div class="cover-preview" id="coverPreview">
                        <img id="coverPreviewImg" src="@Model.CoverImagePath" alt="Preview ảnh bìa" />
                        <div class="file-name" id="coverFileName"><i class="fa-solid fa-image" style="color: #888;"></i> Ảnh hiện tại</div>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 40px;">
                    <button type="submit" class="btn-submit" id="btnSubmit">
                        <i class="fa-solid fa-save"></i> LƯU THAY ĐỔI
                    </button>
                </div>
                
                <div class="text-center" style="text-align: center;">
                    <a href="/Admin#magazine" class="back-link"><i class="fa-solid fa-arrow-left"></i> Hủy và Quay lại</a>
                </div>
            </form>
        </div>
    </main>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // =========================================================================
        // 1. BỘ ĐẾM KÝ TỰ REAL-TIME
        // =========================================================================
        function setupCharCounter(inputId, counterId, maxLen) {
            var input = document.getElementById(inputId);
            var counter = document.getElementById(counterId);
            if (!input || !counter) return;

            function update() {
                var len = input.value ? input.value.length : 0;
                counter.textContent = len + ' / ' + maxLen;
                counter.classList.remove('warning', 'danger');
                if (len >= maxLen) {
                    counter.classList.add('danger');
                } else if (len >= maxLen * 0.8) {
                    counter.classList.add('warning');
                }
            }
            input.addEventListener('input', update);
            update(); // Run once on load
        }

        setupCharCounter('inputIssueNumber', 'counterIssueNumber', 10);
        setupCharCounter('inputTitle', 'counterTitle', 40);
        setupCharCounter('inputDescription', 'counterDescription', 500);
        setupCharCounter('inputSeason', 'counterSeason', 30);

        // =========================================================================
        // 2. PREVIEW ẢNH BÌA
        // =========================================================================
        var coverInput = document.getElementById('coverImageInput');
        var coverPreview = document.getElementById('coverPreview');
        var coverPreviewImg = document.getElementById('coverPreviewImg');
        var coverFileName = document.getElementById('coverFileName');
        var fileUploadArea = document.getElementById('fileUploadArea');

        if (coverInput) {
            coverInput.addEventListener('change', function () {
                if (this.files && this.files[0]) {
                    var file = this.files[0];

                    if (!file.type.match('image.*')) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Định dạng không hỗ trợ',
                            text: 'Vui lòng chọn file ảnh (JPG, PNG, WEBP)!',
                            confirmButtonColor: '#B29B84'
                        });
                        this.value = '';
                        return;
                    }

                    if (file.size > 5 * 1024 * 1024) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'File quá lớn',
                            text: 'Ảnh bìa không được vượt quá 5MB!',
                            confirmButtonColor: '#B29B84'
                        });
                        this.value = '';
                        return;
                    }

                    var reader = new FileReader();
                    reader.onload = function (e) {
                        coverPreviewImg.src = e.target.result;
                        coverFileName.innerHTML = '<i class="fa-solid fa-check-circle" style="color: #27ae60;"></i> ' + file.name + ' (Ảnh mới)';
                        fileUploadArea.classList.add('has-file');
                    };
                    reader.readAsDataURL(file);
                }
            });
        }
    </script>
}
