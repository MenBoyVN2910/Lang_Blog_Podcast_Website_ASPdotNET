            {
                <div style="text-align: center; color: var(--text-muted); font-style: italic; padding: 40px 0;">
                    <i class="fa-regular fa-folder-open" style="font-size: 32px; color: #ddd; display: block; margin-bottom: 12px;"></i>
                    Chưa có câu chuyện nào được xuất bản.
                </div>
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;" id="publishedStoriesGrid">
                    @foreach (var story in Model.ApprovedStories)
                    {
                        string storyPlainText = string.IsNullOrEmpty(story.Content) ? "" : Regex.Replace(story.Content, "<.*?>", string.Empty);
                        string storyExcerpt = storyPlainText.Length > 120 ? storyPlainText.Substring(0, 120) + "..." : storyPlainText;

                        <div class="published-card" data-title="@story.Title?.ToLower()">
                            <div style="display: flex; gap: 14px;">
                                <div style="width: 80px; height: 80px; flex-shrink: 0; border-radius: 8px; overflow: hidden; background: #f5f5f5;">
                                    <img src="@(string.IsNullOrEmpty(story.ImagePath) ? "/images/Default_Images/Blog.png" : story.ImagePath)" alt="@story.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                                <div style="flex: 1; min-width: 0;">
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;">
                                        <h4 style="margin: 0; font-size: 15px; font-weight: 700; color: var(--primary-deep); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;">@story.Title</h4>
                                        <span class="badge" style="background: var(--accent-green-bg); color: var(--accent-green); font-size: 10px; padding: 3px 8px;">Đã duyệt</span>
                                    </div>
                                    <div style="font-size: 11px; color: #999; margin-bottom: 6px; display: flex; gap: 12px; flex-wrap: wrap;">
                                        <span><i class="fa-regular fa-user"></i> @(story.User?.FullName ?? "Ẩn danh")</span>
                                        <span><i class="fa-regular fa-clock"></i> @story.PublishDate?.ToString("dd/MM/yyyy")</span>
                                        <span><i class="fa-regular fa-eye"></i> @story.ViewCount</span>
                                    </div>
                                    <p style="margin: 0; font-size: 12px; color: #888; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@storyExcerpt</p>
                                </div>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding-top: 10px; border-top: 1px solid #f5f5f5;">
                                <span class="badge" style="font-size: 10px;">@(story.Category?.Name ?? "Chưa rõ")</span>
                                <div style="display: flex; gap: 6px;">
                                    <a href="/Story/Details/@story.Id" target="_blank" style="padding: 5px 10px; font-size: 11px; border: 1px solid #eee; border-radius: 4px; text-decoration: none; color: #666; transition: all 0.2s;" title="Xem bài viết" onmouseover="this.style.borderColor='#B29B84'; this.style.color='#B29B84';" onmouseout="this.style.borderColor='#eee'; this.style.color='#666';"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                                    <form asp-action="DeleteApprovedStory" method="post" style="margin: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn gỡ bài viết này khỏi hệ thống?');">
                                        <input type="hidden" name="id" value="@story.Id" />
                                        <button type="submit" style="padding: 5px 10px; font-size: 11px; border: 1px solid #fdd; border-radius: 4px; background: none; color: var(--accent-red); cursor: pointer; transition: all 0.2s;" title="Gỡ bài" onmouseover="this.style.background='var(--accent-red-bg)';" onmouseout="this.style.background='none';"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* --- Sub-Tab 2: Approved Podcasts --- *@
        <div id="pub-podcasts" class="pub-sub-content">
            @if (Model.ApprovedPodCasts.Count == 0)
            {
                <div style="text-align: center; color: var(--text-muted); font-style: italic; padding: 40px 0;">
                    <i class="fa-solid fa-podcast" style="font-size: 32px; color: #ddd; display: block; margin-bottom: 12px;"></i>
                    Chưa có Podcast nào được xuất bản.
                </div>
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;" id="publishedPodcastsGrid">
                    @foreach (var pc in Model.ApprovedPodCasts)
                    {
                        string pcDesc = pc.Description?.Length > 120 ? pc.Description.Substring(0, 120) + "..." : (pc.Description ?? "");

                        <div class="published-card" data-title="@pc.Title?.ToLower()">
                            <div style="display: flex; gap: 14px;">
                                <div style="width: 80px; height: 80px; flex-shrink: 0; border-radius: 8px; overflow: hidden; background: #f5f5f5; position: relative;">
                                    <img src="@(string.IsNullOrEmpty(pc.ImagePath) ? "/images/Default_Images/Blog.png" : pc.ImagePath)" alt="@pc.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                                    <div style="position: absolute; bottom: 4px; right: 4px; background: rgba(0,0,0,0.7); color: #fff; font-size: 9px; padding: 2px 5px; border-radius: 3px;"><i class="fa-solid fa-headphones"></i></div>
                                </div>
                                <div style="flex: 1; min-width: 0;">
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;">
                                        <h4 style="margin: 0; font-size: 15px; font-weight: 700; color: var(--primary-deep); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;">@pc.Title</h4>
                                        <span style="font-size: 10px; background: #E8F0FF; color: #4A7ADB; padding: 3px 8px; border-radius: 10px; font-weight: 600; white-space: nowrap;">Tập @(pc.EpisodeNumber ?? 0)</span>
                                    </div>
                                    <div style="font-size: 11px; color: #999; margin-bottom: 6px; display: flex; gap: 12px; flex-wrap: wrap;">
                                        <span><i class="fa-regular fa-user"></i> @(string.IsNullOrEmpty(pc.User?.FullName) ? (string.IsNullOrEmpty(pc.Author) ? "Ẩn danh" : pc.Author) : pc.User.FullName)</span>
                                        <span><i class="fa-regular fa-clock"></i> @pc.PublishDate?.ToString("dd/MM/yyyy")</span>
                                        <span><i class="fa-regular fa-eye"></i> @pc.ViewCount</span>
                                        @if (!string.IsNullOrEmpty(pc.Duration))
                                        {
                                            <span><i class="fa-solid fa-stopwatch"></i> @pc.Duration</span>
                                        }
                                    </div>
                                    <p style="margin: 0; font-size: 12px; color: #888; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@pcDesc</p>
                                </div>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding-top: 10px; border-top: 1px solid #f5f5f5;">
                                <span class="badge" style="font-size: 10px;">@(pc.Category?.Name ?? "Chưa rõ")</span>
                                <div style="display: flex; gap: 6px;">
                                    <a href="/PodCast/Details/@pc.Id" target="_blank" style="padding: 5px 10px; font-size: 11px; border: 1px solid #eee; border-radius: 4px; text-decoration: none; color: #666; transition: all 0.2s;" title="Xem Podcast" onmouseover="this.style.borderColor='#B29B84'; this.style.color='#B29B84';" onmouseout="this.style.borderColor='#eee'; this.style.color='#666';"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                                    <form asp-action="DeleteApprovedPodcast" method="post" style="margin: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn gỡ Podcast này khỏi hệ thống?');">
                                        <input type="hidden" name="id" value="@pc.Id" />
                                        <button type="submit" style="padding: 5px 10px; font-size: 11px; border: 1px solid #fdd; border-radius: 4px; background: none; color: var(--accent-red); cursor: pointer; transition: all 0.2s;" title="Gỡ bài" onmouseover="this.style.background='var(--accent-red-bg)';" onmouseout="this.style.background='none';"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* =====================Danh Mục========================================== *@
    <div id="tab-categories" class="tab-content">
        <h2 class="section-title">Cấu trúc danh mục hiện tại</h2>

        <form asp-controller="Admin" asp-action="CreateCategory" method="post" class="input-group">
            @Html.AntiForgeryToken()
