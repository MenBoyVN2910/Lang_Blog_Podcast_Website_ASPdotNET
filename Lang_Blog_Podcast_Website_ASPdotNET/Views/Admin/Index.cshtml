@model Lang_Blog_Podcast_Website_ASPdotNET.Models.AdminDashboardViewModel
@using System.Text.Encodings.Web
@using System.Text.RegularExpressions
@inject Lang_Blog_Podcast_Website_ASPdotNET.Data.ApplicationDbContext DbContext

@{
    ViewData["Title"] = "Ban Biên Tập - Hệ thống quản trị";

}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="~/css/Admin/Index.css" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
@* ======================================================================================================================================================== *@





@* ======================================================================================================================================================== *@
<div class="admin-container admin-layout">
    <aside class="admin-sidebar">
        <header class="admin-header">
            <div class="header-text">
                <p>Hệ thống tòa soạn</p>
                <h1>Ban Biên Tập.</h1>
            </div>
        </header>

        @* =====================Navigation Menu========================================== *@
        <nav class="admin-tabs">
            <button class="tab-btn active" onclick="openTab(event, 'stories')"><i class="fa-solid fa-book-open"></i> Mảnh ghép ký ức</button>
            <button class="tab-btn" onclick="openTab(event, 'posts')"><i class="fa-regular fa-newspaper"></i> Bài viết tạp chí</button>
            <button class="tab-btn" onclick="openTab(event, 'podcast')"><i class="fa-solid fa-headphones"></i> PodCast Series</button>
            <button class="tab-btn" onclick="openTab(event, 'categories')"><i class="fa-solid fa-list"></i> Quản lý danh mục</button>
            <button class="tab-btn" onclick="openTab(event, 'manageusers')"><i class="fa-solid fa-list"></i> Quản lý người dùng</button>
        </nav>
    </aside>


    @* =====================Menu admin========================================== *@
    <main class="admin-main">
        @if (TempData["AdminMessage"] != null)
        {
            <div class="alert-box">@TempData["AdminMessage"]</div>
        }

        <section class="stats-wrapper">
            <div class="stat-card">
                <span class="stat-title">Câu chuyện chờ duyệt</span>
                <div class="stat-number">
                    @Model.PendingCount.ToString("D2")
                    <span class="stat-unit">bài mới</span>
                </div>
            </div>
            <div class="stat-card">
                <span class="stat-title">Ấn phẩm tạp chí</span>
                <div class="stat-number">
                    @Model.ApprovedCount.ToString("D2")
                    <span class="stat-unit">bài viết</span>
                </div>
            </div>
            <div class="stat-card">
                <span class="stat-title">Tổng số danh mục</span>
                <div class="stat-number">
                    @Model.TotalCategoriesCount.ToString("D2")
                    <span class="stat-unit">chủ đề</span>
                </div>
            </div>
        </section>


    @* =====================Blog========================================== *@
    <div id="stories" class="tab-content active">
        <h2 class="section-title">Phê duyệt tâm sự từ độc giả</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 18%;">Người gửi</th>
                    <th style="width: 15%;">Chủ đề</th>
                    <th style="width: 47%;">Nội dung tâm sự</th>
                    <th style="width: 20%; text-align: right;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PendingCount == 0)
                {
                    <tr>
                        <td colspan="4" style="text-align: center; color: var(--text-muted); font-style: italic;">
                            Hiện tại không có câu chuyện nào đang chờ duyệt.
                        </td>
                    </tr>
                }
                else
                {
                    int index = 0;
                    @foreach (var story in Model.PendingStories)
                    {
                        // 1. Chuyển đổi nội dung HTML thành Text thuần
                        string plainText = string.IsNullOrEmpty(story.Content) ? "" : Regex.Replace(story.Content, "<.*?>", string.Empty);

                        // 2. Tách thành mảng các từ và giới hạn 25 từ
                        string[] words = plainText.Split(new[] { ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries);
                        string excerpt = words.Length > 25 ? string.Join(" ", words.Take(25)) + "..." : plainText;
                        if (excerpt.Length > 150) excerpt = excerpt.Substring(0, 150) + "...";

                        <tr>
                            <td>
                                <div class="user-info">
                                    @if (story.User?.ProfilePicture != null)
                                    {
                                        <img src="data:image/*;base64,@(Convert.ToBase64String(story.User.ProfilePicture))" alt="Avatar" class="avatar" style="object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="avatar">@(string.IsNullOrEmpty(story.User?.FullName ?? story.Author) ? "?" : (story.User?.FullName ?? story.Author).Substring(0, 1).ToUpper())</div>
                                    }
                                    <div class="user-details">
                                        <strong>@(string.IsNullOrEmpty(story.User?.FullName) ? (string.IsNullOrEmpty(story.Author) ? "Ẩn danh" : story.Author) : story.User.FullName)</strong>
                                        <span>@story.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge">@(story.Category?.Name ?? "Chưa rõ")</span></td>
                            <td>
                                <div class="post-content">
                                    <h4>@(story.Title?.Length > 20 ? story.Title.Substring(0, 20) + "..." : story.Title)</h4>

                                    <!-- Hiển thị bản trích dẫn 25 từ -->
                                    <div class="post-summary-box" id="summary-@index" style="word-break: break-word;">
                                        @Html.Raw(excerpt)
                                    </div>

                                    <button class="btn-view-more btn-open-modal"
                                            data-title="@story.Title"
                                            data-author="@(string.IsNullOrEmpty(story.User?.FullName) ? (story.Author ?? "Ẩn danh") : story.User.FullName)"
                                            data-issuenumber="@(story.IssueNumber ?? "None")"
                                            data-time="@story.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                            data-image="@(string.IsNullOrEmpty(story.ImagePath) ? "/images/Default_Images/Blog.png" : story.ImagePath)"
                                            data-target="content-data-@index">
                                        <i class="fa-regular fa-eye"></i> <span>Đọc toàn bộ nội dung</span>
                                    </button>

                                    <!-- VẪN GIỮ NGUYÊN BẢN GỐC CÓ HTML ĐỂ HIỂN THỊ TRONG POP-UP -->
                                    <div id="content-data-@index" style="display:none;">
                                        @Html.Raw(story.Content)
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="action-group">
                                    <form asp-controller="Admin" asp-action="Approve" asp-route-id="@story.Id" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action approve"><i class="fa-solid fa-check me-1"></i> Duyệt</button>
                                    </form>
                                    <form asp-controller="Admin" asp-action="Reject" asp-route-id="@story.Id" method="post" style="margin:0;" onsubmit="return confirm('Bạn có chắc muốn xóa bài viết này vĩnh viễn?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action reject"><i class="fa-solid fa-trash-can me-1"></i> Bỏ</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
            </tbody>
        </table>
    </div>



    @* =====================Magazine========================================== *@
    <div id="posts" class="tab-content">
        <h2 class="section-title">Danh sách bài viết tạp chí</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 15%;">Hình ảnh</th>
                    <th style="width: 40%;">Tiêu đề</th>
                    <th style="width: 15%;">Danh mục</th>
                    <th style="width: 15%;">Ngày đăng</th>
                    <th style="width: 15%; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--text-muted); font-style: italic; padding: 30px;">
                        Chưa có bài viết nào được xuất bản trên tạp chí. Phần này sẽ code chức năng sau.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>


    @* =====================PodCast========================================== *@
    <div id="podcast" class="tab-content">
        <h2 class="section-title">Những Thanh Âm Chạm Đến Trái Tim</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 15%;">Hình ảnh</th>
                    <th style="width: 40%;">Tiêu đề</th>
                    <th style="width: 15%;">Danh mục</th>
                    <th style="width: 15%;">Ngày đăng</th>
                    <th style="width: 15%; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--text-muted); font-style: italic; padding: 30px;">
                        Chưa có bài viết nào được xuất bản trên tạp chí. Phần này sẽ code chức năng sau.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* =====================Danh Mục========================================== *@
    <div id="categories" class="tab-content">
        <h2 class="section-title">Cấu trúc danh mục hiện tại</h2>

        <form asp-controller="Admin" asp-action="CreateCategory" method="post" class="input-group">
            @Html.AntiForgeryToken()
            <input type="text" name="CategoryName" class="input-field" placeholder="Tên danh mục mới (VD: Triết lý)..." required />
            <button type="submit" class="btn primary">Thêm danh mục</button>
        </form>

        <div style="max-width: 600px;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 25%;">Mã ID</th>
                        <th style="width: 55%;">Tên danh mục</th>
                        <th style="width: 20%; text-align: right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model.Categories)
                    {
                        <tr>
                            <td style="color: var(--text-muted);">#@cat.Id.ToString("D2")</td>
                            <td><strong>@cat.Name.ToUpper()</strong></td>
                            <td>
                                <form asp-controller="Admin" asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post" style="text-align: right; margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action reject">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </div>

        @* =====================ManageUsers========================================== *@
        <div id="manageusers" class="tab-content">
            <h2 class="section-title">Quản lý phân quyền hệ thống</h2>

            <!-- Form thêm người dùng mới -->
            <div class="add-user-container">
                <h3 class="subsection-title">Thêm người dùng mới</h3>
                <form asp-controller="Admin" asp-action="CreateUser" method="post" class="add-user-form">
                    @Html.AntiForgeryToken()
                    <div class="form-row">
                        <div class="form-col">
                            <input type="text" name="fullName" class="input-field" placeholder="Họ và tên..." required style="width: 100%; height: 48px;" />
                        </div>
                        <div class="form-col">
                            <input type="email" name="email" class="input-field" placeholder="Địa chỉ email..." required style="width: 100%; height: 48px;" />
                        </div>
                        <div class="form-col">
                            <input type="password" name="password" class="input-field" placeholder="Mật khẩu..." required style="width: 100%; height: 48px;" />
                        </div>
                        <div class="form-col select-col">
                            <select name="role" class="select-field">
                                <option value="Reader">Độc giả</option>
                                <option value="Admin">Quản trị viên (Admin)</option>
                            </select>
                        </div>
                        <div class="form-col action-col">
                            <button type="submit" class="btn primary btn-add-user"><i class="fa-solid fa-user-plus"></i> Thêm</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="lang-table-wrapper">
                <table class="lang-table">
                    <thead>
                        <tr>
                            <th>Tài khoản</th>
                            <th>Email</th>
                            <th>Vai trò</th>
                            <th style="text-align: right;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="user-name-cell">@user.UserName</td>
                                <td style="color: #555;">@user.Email</td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge-role badge-admin">
                                            <i class="fa-solid fa-user-shield" style="margin-right: 4px; font-size: 11px;"></i> Admin
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-role badge-reader">Độc giả</span>
                                    }
                                </td>
                                <td style="text-align: right;">
                                    <form asp-action="ToggleAdminRole" method="post" style="display: inline;" onsubmit="return confirm('Bạn có chắc chắn muốn thay đổi quyền của tài khoản này không?');">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        @if (user.IsAdmin)
                                        {
                                            <button type="submit" class="btn-action btn-revoke">
                                                <i class="fa-solid fa-user-minus" style="font-size: 12px;"></i> Gỡ quyền
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn-action btn-grant">
                                                <i class="fa-solid fa-user-plus" style="font-size: 12px;"></i> Cấp quyền Admin
                                            </button>
                                        }
                                    </form>

                                    <form asp-action="DeleteUser" method="post" style="display: inline; margin-left: 8px;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn tài khoản này không?');">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="btn-action btn-delete-user">
                                            <i class="fa-solid fa-trash-can" style="font-size: 12px;"></i> Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
@* =====================Blog Details========================================== *@
<div id="storyModal" class="story-modal" style="display: none;" onclick="closeStoryModal(event)">
    <div class="story-modal-content">
        <div class="story-modal-header">
            <div>
                <h3 id="modalTitle">Tiêu đề bài viết</h3>
                <div class="story-modal-meta" style="display: flex; flex-direction: column; align-items: flex-start; gap: 4px;">
                    <div>
                        <span><i class="fa-regular fa-user"></i> Tác giả: <strong id="modalAuthor" style="color:var(--primary-deep)"></strong></span>
                        <span style="margin-left: 15px;"><i class="fa-regular fa-clock"></i> Thời gian: <span id="modalTime"></span></span>

                        <!-- 💡 NÚT XEM ẢNH BÌA THÊM VÀO ĐÂY (KẾ BÊN THỜI GIAN) -->
                        <span id="modalImageWrapper" style="margin-left: 15px;">
                            <a id="modalImageLink" href="#" target="_blank" style="color: #B29B84; text-decoration: none; font-weight: 600; transition: color 0.2s;">
                                <i class="fa-regular fa-image"></i> Xem ảnh bìa
                            </a>
                        </span>
                    </div>
                    <div style="margin-top: 2px;">
                        <span><i class="fa-solid fa-hashtag"></i> Số phát hành: <strong id="modalIssueNumber" style="color:var(--primary-deep)"></strong></span>
                    </div>
                </div>
            </div>
            <button class="close-modal-btn" onclick="document.getElementById('storyModal').style.display = 'none'">&times;</button>
        </div>

        <!-- Ruột modal chỉ chứa chữ thuần khiết, không bị dính ảnh to nữa -->
        <div class="story-modal-body" id="modalBody">
        </div>

        <div class="story-modal-footer">
            <button class="btn outline" style="padding: 8px 20px;" onclick="document.getElementById('storyModal').style.display = 'none'">Đóng lại</button>
        </div>
    </div>
</div>
@* ======================================================================================================================================================== *@




@* ======================================================================================================================================================== *@
@section Scripts {
    <script>
        function openTab(evt, tabId) {
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => content.classList.remove('active'));
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            evt.currentTarget.classList.add('active');
            
            // Cập nhật URL hash bằng history.replaceState để tránh trình duyệt tự động cuộn màn hình
            history.replaceState(null, null, '#' + tabId);
        }

        // Tự động khôi phục tab đang chọn từ URL hash khi tải trang
        window.addEventListener("DOMContentLoaded", function () {
            const hash = window.location.hash;
            if (hash) {
                const tabId = hash.substring(1); // Bỏ dấu '#'
                const targetBtn = document.querySelector(`.tab-btn[onclick*="'${tabId}'"]`);
                if (targetBtn) {
                    openTab({ currentTarget: targetBtn }, tabId);
                }
            }
        });

        // Tự động bắt sự kiện khi click vào nút "Đọc toàn bộ nội dung"
        document.addEventListener("DOMContentLoaded", function () {
            const viewButtons = document.querySelectorAll(".btn-open-modal");

            viewButtons.forEach(button => {
                button.addEventListener("click", function () {
                    // Đọc dữ liệu an toàn từ các thuộc tính data-*
                    const title = this.getAttribute("data-title");
                    const author = this.getAttribute("data-author");
                    const issueNumber = this.getAttribute("data-issuenumber");
                    const time = this.getAttribute("data-time");
                    const imageSrc = this.getAttribute("data-image"); // Lấy link ảnh bìa từ data-image
                    const targetId = this.getAttribute("data-target");

                    document.getElementById('modalTitle').innerText = title;
                    document.getElementById('modalAuthor').innerText = author;
                    document.getElementById('modalIssueNumber').innerText = issueNumber;
                    document.getElementById('modalTime').innerText = time;

                    // 💡 XỬ LÝ NÚT XEM ẢNH BÌA KẾ BÊN THỜI GIAN
                    const imageLink = document.getElementById('modalImageLink');
                    const imageWrapper = document.getElementById('modalImageWrapper');

                    if (imageLink && imageWrapper) {
                        if (imageSrc) {
                            imageLink.href = imageSrc; // Gán link ảnh vào thuộc tính href
                            imageWrapper.style.display = 'inline'; // Hiển thị nút ra
                        } else {
                            imageWrapper.style.display = 'none'; // Ẩn nút đi nếu không có ảnh
                        }
                    }

                    // Lấy nội dung gốc HTML nạp thẳng vào ruột Modal
                    var rawHtml = document.getElementById(targetId).innerHTML;
                    document.getElementById('modalBody').innerHTML = rawHtml;

                    // Hiển thị modal
                    document.getElementById('storyModal').style.display = 'flex';
                });
            });
        });

        function closeStoryModal(e) {
            if (e.target.id === 'storyModal') {
                document.getElementById('storyModal').style.display = 'none';
            }
        }
    </script>
}
@* ======================================================================================================================================================== *@