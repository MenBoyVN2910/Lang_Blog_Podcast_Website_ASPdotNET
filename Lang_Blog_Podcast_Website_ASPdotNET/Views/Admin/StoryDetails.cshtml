@model Lang_Blog_Podcast_Website_ASPdotNET.Models.Story

@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="~/css/Admin/StoryDetails.css" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 border-right bg-white">
            <div class="story-preview">
                <h1 class="editorial-title">@Model.Title</h1>

                <div class="row mt-5">
                    <div class="col-md-3">
                        <div class="meta-side mb-4">
                            <label>Tác giả</label><br />
                            <span class="text-dark">@Model.Author</span>
                        </div>
                        <div class="meta-side">
                            <label>Ngày gửi</label><br />
                            <span class="text-dark">@Model.CreatedAt.ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>
                    <div class="col-md-9">
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <img src="@Model.ImagePath" class="w-100 mb-5" />
                        }
                        <div class="content-body">
                            @Model.Content
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 p-5 bg-light" style="height: 100vh; position: sticky; top: 0;">
            <h5 class="lang-label">Quyết định biên tập</h5>
            <hr />
            <form asp-action="Approve" method="post" class="mt-4">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="form-group mb-4">
                    <label class="small fw-bold">SỐ PHÁT HÀNH CHÍNH THỨC</label>
                    <input type="text" name="finalIssueNumber" class="form-control rounded-0" value="@Model.IssueNumber" />
                </div>
                <button type="submit" class="btn btn-dark w-100 rounded-0 py-3 mb-2">DUYỆT & XUẤT BẢN</button>
            </form>

            <form asp-action="Reject" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger w-100 rounded-0 py-2">TỪ CHỐI</button>
            </form>

            <a asp-action="ReviewStories" class="d-block text-center mt-4 small text-muted text-decoration-none">← Quay lại hộp thư</a>
        </div>
    </div>
</div>
@* ======================================================================================================================================================== *@