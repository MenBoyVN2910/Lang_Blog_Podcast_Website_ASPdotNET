@{
    ViewData["Title"] = "";
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Home/About.css" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="about-page-wrapper">
    <header class="about-hero">
        <img src="~/images/about.png" class="about-hero-bg" alt="About Background" />
        <div class="about-hero-content">
            <span class="about-hero-subtitle animate-text-up delay-1">Tuyên ngôn của sự tĩnh lặng</span>
            <h1 class="about-hero-title animate-text-up delay-2">
                Chút Lặng <br /> <span class="italic">giữa nhân gian.</span>
            </h1>
        </div>
    </header>

    <section class="about-story-section">
        <div data-aos="fade-right" data-aos-duration="1200">
            <span class="about-section-tag">Sự ra đời</span>
            <p class="about-story-quote">
                "Lặng được thành lập vào một buổi chiều mùa thu năm 2026, từ khao khát tìm thấy một khoảng nghỉ cho những tâm hồn mệt nhoài."
            </p>
            <p class="about-story-desc">
                Giữa những dòng chảy hối hả của thông tin và sự ồn ào của mạng xã hội, chúng tôi nhận ra rằng con người đang dần đánh mất khả năng lắng nghe chính mình. Lặng ra đời không chỉ là một trang web, một tạp chí, mà là một không gian tinh thần - nơi mỗi câu chuyện, mỗi giai điệu podcast được gieo mầm từ sự chân thành và tĩnh lặng.
            </p>
        </div>

        <div data-aos="fade-left" data-aos-duration="1200" data-aos-delay="200">
            <div class="about-story-img-wrapper">
                <img src="~/images/Logo/logo_website.png" class="about-story-img" alt="Office Studio" />
            </div>
        </div>
    </section>

    <section class="about-values-grid">
        <div class="about-value-item" data-aos="fade-up" data-aos-duration="1000">
            <div class="about-value-line"></div>
            <h4 class="about-value-title">Cảm hứng</h4>
            <p class="about-value-text">Vẻ đẹp của sự tối giản (Minimalism) và tinh thần Wabi-sabi Nhật Bản.</p>
        </div>
        <div class="about-value-item" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="150">
            <div class="about-value-line"></div>
            <h4 class="about-value-title">Sứ mệnh</h4>
            <p class="about-value-text">Kết nối những rung động tinh tế nhất qua văn chương và âm thanh.</p>
        </div>
        <div class="about-value-item" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="300">
            <div class="about-value-line"></div>
            <h4 class="about-value-title">Cam kết</h4>
            <p class="about-value-text">Nội dung 100% được gieo mầm từ cảm xúc thật, không chạy theo trào lưu.</p>
        </div>
    </section>

    <section class="about-contact-section">
        <span class="about-section-tag" data-aos="fade-in">Thông tin liên hệ</span>

        <div class="about-contact-container">
            <div class="about-contact-info-list">
                <div class="about-contact-item" data-aos="fade-up" data-aos-delay="100">
                    <div class="about-contact-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
                    </div>
                    <div>
                        <div class="about-contact-label">Xưởng sáng tạo</div>
                        <div class="about-contact-value">Số 123 Đường ABC,TP HCM</div>
                    </div>
                </div>

                <div class="about-contact-item" data-aos="fade-up" data-aos-delay="200">
                    <div class="about-contact-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
                    </div>
                    <div>
                        <div class="about-contact-label">Hòm thư tâm tình</div>
                        <div class="about-contact-value">buiminhnhat2910@gmail.com</div>
                    </div>
                </div>

                <div class="about-contact-item" data-aos="fade-up" data-aos-delay="300">
                    <div class="about-contact-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                    </div>
                    <div>
                        <div class="about-contact-label">Đường dây nóng</div>
                        <div class="about-contact-value">+84 12 345 6789</div>
                    </div>
                </div>

                <div class="about-contact-item" data-aos="fade-up" data-aos-delay="300">
                    <div>
                        <div class="about-contact-value">Bơm máu cho lặng bằng cách:</div>
                        <img src="~/images/QRcode.png" class="qr_code" alt="QRcore Bank" />
                    </div>
                </div>
                
                
            </div>

            <div class="about-form-card" data-aos="zoom-in-up" data-aos-duration="1000">
                <form method="post">
                    <div class="about-form-group">
                        <label class="about-form-label">Tên của bạn</label>
                        <input type="text" class="about-form-input" placeholder="VÍ DỤ: LÊ AN" required />
                    </div>
                    <div class="about-form-group">
                        <label class="about-form-label">Địa chỉ Email</label>
                        <input type="email" class="about-form-input" placeholder="EMAIL@EXAMPLE.COM" required />
                    </div>
                    <div class="about-form-group">
                        <label class="about-form-label">Lời nhắn nhủ</label>
                        <textarea class="about-form-textarea" rows="4" placeholder="VIẾT TẠI ĐÂY..." required></textarea>
                    </div>
                    <button type="submit" class="about-btn-submit">Đang Phát Triển ....</button>
                </form>
            </div>
        </div>
    </section>
</div>
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
@section Scripts {
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>

<script>
    AOS.init({
    once: true,       // Hiệu ứng chỉ chạy 1 lần khi cuộn qua để tránh rối mắt
    offset: 60,       // Kích hoạt hiệu ứng sớm hơn 1 chút
    easing: 'ease-out-cubic' // Gia tốc mượt mà, chậm dần về cuối
    });
</script>
}
@* ======================================================================================================================================================== *@