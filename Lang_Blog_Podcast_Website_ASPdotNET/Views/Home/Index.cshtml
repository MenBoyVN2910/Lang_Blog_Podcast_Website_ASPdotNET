@using Lang_Blog_Podcast_Website_ASPdotNET.Models
@{
    ViewData["Title"] = "Trang Chủ";
    var topPodcasts = ViewBag.TopPodcasts as List<PodCast> ?? new List<PodCast>();
    var topStories = ViewBag.TopStories as List<Story> ?? new List<Story>();
}
@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/Home/Index.css" />
@* ======================================================================================================================================================== *@

<header class="main-header"></header>

<div class="magazine-container">

    <main class="main-content-area">
        <div class="home-hero-section">
            <div class="hero-meta animate-hero delay-1">
                <span class="badge featured-badge">FEATURED EDITORIAL</span>
                <span class="issue-date">@DateTime.Now.ToString("MMM yyyy").ToUpper() ISSUE</span>
            </div>
            <h1 class="serif-title-xl animate-hero delay-2">Im lặng <br>là một ngôn từ.</h1>
        </div>


        <!-- Bắt Đầu Hero Carousel -->
        <div class="hero-carousel" data-aos="fade-up" data-aos-duration="1200">
            <div class="carousel-inner">
                @if (ViewBag.CarouselItems != null)
                {
                    int index = 0;
                    foreach (var item in ViewBag.CarouselItems)
                    {
                        string defaultImg = item.Type == "podcast" ? "/images/Logo/logo_website.png" : "/images/default-thumbnail.jpg";
                        string imgPath = string.IsNullOrEmpty(item.ImagePath) ? defaultImg : item.ImagePath;
                        string url = item.Type == "podcast" ? Url.Action("Details", "Podcast", new { id = item.Id }) : Url.Action("Details", "Story", new { id = item.Id });
                        
                        <div class="carousel-slide @(index == 0 ? "active" : "")" data-index="@index">
                            <a href="@url" class="image-aesthetic-wrapper">
                                @if (item.Type == "podcast")
                                {
                                    <span class="carousel-badge carousel-badge-podcast"><i class="fa-solid fa-headphones"></i> PODCAST</span>
                                }
                                else
                                {
                                    <span class="carousel-badge carousel-badge-story"><i class="fa-solid fa-book-open"></i> BÀI VIẾT</span>
                                }
                                <div class="image-zoom-container carousel-image-container">
                                    <img src="@imgPath" alt="@item.Title" class="grid-image" onerror="this.src='@defaultImg'" />
                                </div>
                            </a>
                            <div class="post-text-content carousel-text">
                                <h2 class="serif-title-lg">@item.Title</h2>
                                <p class="article-excerpt">@Html.Raw(item.Description)</p>
                                <div class="carousel-meta">
                                    <span>Bởi <strong>@item.Author</strong></span> &bull; 
                                    <span>@item.CreatedAt.ToString("dd.MM.yyyy")</span> &bull; 
                                    <span><i class="fa-solid fa-eye"></i> @item.ViewCount</span>
                                </div>
                                @if (item.Type == "podcast" && !string.IsNullOrEmpty(item.AudioPath))
                                {
                                    <a href="javascript:void(0)" onclick="playPodcast('@item.AudioPath', '@item.Title', '@item.Author', '@imgPath', @item.Id)" class="read-more-link"><i class="fa-solid fa-play"></i> NGHE NGAY &rarr;</a>
                                }
                                else
                                {
                                    <a href="@url" class="read-more-link">KHÁM PHÁ NGAY &rarr;</a>
                                }
                            </div>
                        </div>
                        index++;
                    }
                }
            </div>

            <div class="carousel-controls">
                <button class="carousel-nav-btn prev-btn"><i class="fa-solid fa-chevron-left"></i></button>
                <div class="carousel-dots">
                    @if (ViewBag.CarouselItems != null)
                    {
                        int index = 0;
                        foreach (var item in ViewBag.CarouselItems)
                        {
                            <span class="dot @(index == 0 ? "active" : "")" data-index="@index"></span>
                            index++;
                        }
                    }
                </div>
                <button class="carousel-nav-btn next-btn"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
            <div class="carousel-progress-container">
                <div class="carousel-progress-bar"></div>
            </div>
        </div>
        <!-- Kết Thúc Hero Carousel -->


        <!-- CHƯƠNG TRÌNH THEO MÙA -->
        <div class="horizontal-post" data-aos="fade-up" data-aos-duration="1200" data-aos-offset="100">
            <div class="horiz-image">
                <a href="https://www.threads.com/chao_em_hehe/post/DZ-c2mFE2Sw?xmt=AQG0lX5PUUzAdoXsRjgOdhWtoei2V5_1pP5DADxDjfOJYg" class="image-aesthetic-wrapper">
                    <div class="image-zoom-container">
                        <img src="~/images/Bia.png" alt="Chair and branch" class="grid-image" />
                    </div>
                </a>
            </div>
            <div class="horiz-text">
                <span class="section-title-sans">CHƯƠNG TRÌNH THEO MÙA</span>
                <h2 class="serif-title-md">BẢN GIAO HƯỞNG CỦA NHỮNG NGÀY MƯA.</h2>
                <p class="article-excerpt">Khi tiếng mưa rơi hòa quyện cùng sự tĩnh lặng của căn phòng, ta bắt gặp chính mình trong những suy tư sâu thẳm nhất.</p>
                <a href="https://www.threads.com/chao_em_hehe/post/DZ-c2mFE2Sw?xmt=AQG0lX5PUUzAdoXsRjgOdhWtoei2V5_1pP5DADxDjfOJYg" class="btn-outline">KHÁM PHÁ NGAY</a>
            </div>
        </div>
    </main>

    <aside class="sidebar-right-area">

        <!-- THAY ĐỔI: TOP PODCAST -->
        <h3 class="sans-header" data-aos="fade-in">TOP PODCAST</h3>
        <div class="top-list-container">
            @foreach (var podcast in topPodcasts)
            {
                <div class="podcast-card-side" data-aos="fade-left" data-aos-delay="100" onclick="playPodcast('@podcast.AudioPath', '@podcast.Title', '@(podcast.Author ?? podcast.User?.FullName)', '@(string.IsNullOrEmpty(podcast.ImagePath) ? "/images/Logo/logo_website.png" : podcast.ImagePath)', @podcast.Id)">
                    <div class="podcast-img-wrapper">
                        <img src="@(string.IsNullOrEmpty(podcast.ImagePath) ? "/images/Logo/logo_website.png" : podcast.ImagePath)" alt="@podcast.Title" class="side-card-img" />
                    </div>
                    <div class="side-card-info">
                        <span class="tag-new">@podcast.ViewCount <i class="fa-solid fa-headphones"></i> LƯỢT NGHE</span>
                        <h4 class="card-title serif-title">@podcast.Title</h4>
                        <span class="duration"><i class="fa-solid fa-play"></i> Nghe ngay</span>
                    </div>
                </div>
            }
        </div>
        <a href="@Url.Action("Index", "Podcast")" class="view-all-link" data-aos="fade-in">TẤT CẢ PODCAST &rarr;</a>

        <div class="sidebar-divider" style="margin-top: 30px;"></div>

        <!-- THAY ĐỔI: TOP BÀI VIẾT (STORY) -->
        <h3 class="sans-header" data-aos="fade-in" style="margin-top: 20px;">TOP BÀI VIẾT</h3>
        
        @foreach (var story in topStories)
        {
            <div class="sidebar-post" data-aos="fade-up" data-aos-duration="1000">
                <a href="@Url.Action("Details", "Story", new { id = story.Id })" class="image-aesthetic-wrapper">
                    <div class="image-zoom-container" style="height: 180px;">
                        <img src="@(string.IsNullOrEmpty(story.ImagePath) ? "/images/default-thumbnail.jpg" : story.ImagePath)" alt="@story.Title" class="grid-image" style="height: 100%; object-fit: cover;" onerror="this.src='/images/Logo/logo_website.png'" />
                    </div>
                </a>
                <div class="post-meta">
                    <span>@story.CreatedAt.ToString("dd.MM.yyyy")</span> &bull; <span>@story.ViewCount <i class="fa-solid fa-eye"></i></span>
                </div>

                <!-- Fix: Rút gọn tiêu đề tối đa 20 ký tự -->
                <h4 class="serif-title-md" style="margin-top: 5px; font-size: 22px;">
                    @(story.Title?.Length > 20 ? story.Title.Substring(0, 20) + "..." : story.Title)
                </h4>

                <a href="@Url.Action("Details", "Story", new { id = story.Id })" class="read-more-link-small">ĐỌC THÊM &rarr;</a>
            </div>
            <div class="sidebar-divider"></div>
        }

        <div class="editor-quote-block" data-aos="fade-right">
            <span class="section-title-sans">GHI CHÉP TỪ BIÊN TẬP</span>
            <blockquote class="serif-quote">
                "Giữa thế giới ồn ào này, việc tìm thấy một khoảng lặng để lắng nghe chính mình là một món quà xa xỉ."
            </blockquote>
        </div>

        <div class="ecosystem-banner" data-aos="zoom-in">
            <span>HỆ SINH THÁI LẶNG</span>
            <span class="banner-version">v3.0</span>
        </div>

        <a href="@Url.Action("Index", "Story")" class="view-all-link" data-aos="fade-in" style="display: block; text-align: center; margin-top: 20px; font-size: 14px; padding: 15px; border: 1px solid var(--border-color); border-radius: 8px;">XEM TẤT CẢ CÂU CHUYỆN &rarr;</a>

    </aside>

</div>

@section Scripts {
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
    once: true,
    offset: 80,
    duration: 800,
    easing: 'ease-out-cubic'
    });

    // Hàm gọi Player khi click vào podcast ở trang chủ
    function playPodcast(audioPath, title, author, imagePath, podcastId) {
        if (!audioPath) {
            alert('Tệp âm thanh không tồn tại!');
            return;
        }
        if (typeof LangPlayer !== 'undefined') {
            LangPlayer.play(audioPath, title, author, imagePath, podcastId);
        } else if (typeof window.LangPlayer !== 'undefined') {
            window.LangPlayer.play(audioPath, title, author, imagePath, podcastId);
        } else {
            alert('Trình phát âm thanh chưa sẵn sàng. Đang cố gắng tải lại...');
        }
    }

    // Hero Carousel Logic
    document.addEventListener("DOMContentLoaded", function() {
        const slides = document.querySelectorAll('.carousel-slide');
        const dots = document.querySelectorAll('.dot');
        const prevBtn = document.querySelector('.prev-btn');
        const nextBtn = document.querySelector('.next-btn');
        const progressBar = document.querySelector('.carousel-progress-bar');
        const carousel = document.querySelector('.hero-carousel');
        
        let currentSlide = 0;
        let slideInterval;
        const intervalTime = 5000; // 5 seconds
        
        if(slides.length === 0) return;

        function goToSlide(n) {
            slides[currentSlide].classList.remove('active');
            dots[currentSlide].classList.remove('active');
            
            currentSlide = (n + slides.length) % slides.length;
            
            slides[currentSlide].classList.add('active');
            dots[currentSlide].classList.add('active');
            
            resetProgress();
        }

        function nextSlide() {
            goToSlide(currentSlide + 1);
        }

        function prevSlide() {
            goToSlide(currentSlide - 1);
        }

        function startSlide() {
            if(slideInterval) clearInterval(slideInterval);
            slideInterval = setInterval(nextSlide, intervalTime);
            startProgress();
        }

        function stopSlide() {
            clearInterval(slideInterval);
            progressBar.style.animationPlayState = 'paused';
        }

        function startProgress() {
            progressBar.style.animation = 'none';
            progressBar.offsetHeight; /* trigger reflow */
            progressBar.style.animation = `progress ${intervalTime}ms linear infinite`;
            progressBar.style.animationPlayState = 'running';
        }

        function resetProgress() {
            startProgress();
            if(slideInterval) {
                clearInterval(slideInterval);
                slideInterval = setInterval(nextSlide, intervalTime);
            }
        }

        nextBtn.addEventListener('click', () => {
            nextSlide();
        });

        prevBtn.addEventListener('click', () => {
            prevSlide();
        });

        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                goToSlide(index);
            });
        });

        carousel.addEventListener('mouseenter', stopSlide);
        carousel.addEventListener('mouseleave', () => {
            if(slideInterval) {
                startSlide();
            }
        });

        // Initialize
        startSlide();
    });
</script>
}