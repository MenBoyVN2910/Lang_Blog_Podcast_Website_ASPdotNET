@{
    ViewData["Title"] = "Trang chủ - Lặng.";
}

<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">

<style>
    /* ==========================================================================
           1. CẤU HÌNH CHUNG (GLOBAL SETTINGS)
           ========================================================================== */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --font-serif-header: 'Playfair Display', serif;
        --font-sans: 'Montserrat', sans-serif;
        --color-cream: #F5F1EE;
        --color-dark: #1A1817;
        --color-editorial-brown: #5A4634;
        --color-goldaccent: #B3996A;
        --border-color: #DCD7D2;
    }

    html {
        font-size: 14px;
        position: relative;
        min-height: 100%;
        scroll-behavior: smooth; /* Cuộn trang mượt mà */
    }

    @@media (min-width: 768px) {
        html {
            font-size: 16px;
        }
    }

    body {
        font-family: var(--font-sans);
        background-color: var(--color-cream);
        color: var(--color-dark);
        padding-top: 80px;
        margin-bottom: 60px;
        overflow-x: hidden;
    }

    /* ==========================================================================
           2. KHUNG BỐ CỤC CHÍNH (MAGAZINE GRID)
           ========================================================================== */
    .magazine-container {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 60px;
        max-width: 1400px;
        margin: 40px auto;
        padding: 0 40px;
    }

    .main-content-area {
        display: flex;
        flex-direction: column;
        gap: 35px;
    }

    .sidebar-right-area {
        border-left: 1px solid var(--border-color);
        padding-left: 40px;
        display: flex;
        flex-direction: column;
        gap: 35px;
    }

    /* ==========================================================================
           3. THÀNH PHẦN DÙNG CHUNG (ELEMENTS & BADGES)
           ========================================================================== */
    .grid-item {
        position: relative;
        width: 100%;
        overflow: hidden; /* Cần thiết cho hiệu ứng zoom ảnh */
    }

    .grid-image {
        width: 100%;
        height: auto;
        display: block;
        object-fit: cover;
    }

    .badge {
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .featured-badge {
        background-color: var(--color-dark);
        color: #FFFFFF;
    }

    .chữa-lành-badge {
        background-color: var(--color-goldaccent);
        color: #FFFFFF;
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 10;
    }

    .section-title-sans {
        font-size: 12px;
        font-weight: 700;
        color: #77726E;
        letter-spacing: 1.5px;
    }

    .article-excerpt {
        font-size: 14px;
        color: #77726E;
        line-height: 1.8;
        margin-bottom: 25px;
    }

    /* ==========================================================================
           4. TUYẾN NỘI DUNG CHÍNH (MAIN CONTENT AREA)
           ========================================================================== */
    .hero-meta {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .issue-date {
        font-size: 11px;
        color: #77726E;
        letter-spacing: 1px;
    }

    .serif-title-xl {
        font-family: var(--font-serif-header);
        font-size: 85px;
        color: var(--color-editorial-brown);
        font-weight: 400;
        font-style: italic;
        line-height: 1.05;
        letter-spacing: -2px;
        margin-top: 15px;
    }

    .large-post {
        margin-bottom: 60px;
    }

    .post-text-content {
        margin-top: 30px;
        padding-right: 20%;
    }

    .serif-title-lg {
        font-family: var(--font-serif-header);
        font-size: 32px;
        font-style: italic;
        color: var(--color-dark);
        margin-bottom: 15px;
        line-height: 1.2;
    }

    .read-more-link {
        font-size: 11px;
        font-weight: 700;
        color: var(--color-dark);
        text-decoration: none;
        letter-spacing: 1.5px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 5px;
        text-transform: uppercase;
        display: inline-block;
    }

    .horizontal-post {
        display: flex;
        gap: 40px;
        align-items: center;
        border-top: 1px solid var(--border-color);
        padding-top: 50px;
        margin-top: 20px;
    }

    .horiz-image {
        flex: 1;
        overflow: hidden; /* Cần thiết cho zoom ảnh */
    }

    .horiz-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .btn-outline {
        border: 1px solid var(--border-color);
        padding: 12px 25px;
        font-size: 11px;
        font-weight: 700;
        color: var(--color-dark);
        text-decoration: none;
        letter-spacing: 1px;
        margin-top: 10px;
        transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

        .btn-outline:hover {
            background-color: var(--color-dark);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

    /* ==========================================================================
           5. CỘT PHẢI (SIDEBAR AREA)
           ========================================================================== */
    .sans-header {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1.5px;
        color: #77726E;
        text-transform: uppercase;
    }

    .sidebar-divider {
        border-top: 1px solid var(--border-color);
        margin: 10px 0;
    }

    .view-all-link {
        font-size: 12px;
        text-decoration: none;
        color: var(--color-dark);
        font-weight: 700;
        letter-spacing: 1px;
        display: inline-block;
    }

    .podcast-card-side {
        display: flex;
        gap: 20px;
        align-items: center;
        padding: 10px;
        margin-left: -10px;
        border-radius: 8px;
    }

    .podcast-img-wrapper {
        width: 90px;
        height: 90px;
        background-color: #E2DDD9;
        overflow: hidden;
    }

    .side-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .side-card-info {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .tag-new {
        font-size: 10px;
        color: #9A9187;
        letter-spacing: 1px;
    }

    .card-title.serif-title {
        font-family: var(--font-serif-header);
        font-size: 18px;
        font-style: italic;
        font-weight: 700;
        color: var(--color-dark);
        line-height: 1.3;
        transition: color 0.3s ease;
    }

    .duration {
        font-size: 11px;
        color: #9A9187;
    }

    .sidebar-post {
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .post-meta {
        font-size: 10px;
        color: #9A9187;
        letter-spacing: 1px;
        margin: 15px 0 10px 0;
    }

    .serif-title-md {
        font-family: var(--font-serif-header);
        font-size: 26px;
        font-style: italic;
        color: var(--color-dark);
        margin: 15px 0;
        line-height: 1.3;
        transition: color 0.3s ease;
    }

    .article-excerpt-small {
        font-size: 13px;
        color: #77726E;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .read-more-link-small {
        font-size: 11px;
        font-weight: 700;
        color: var(--color-dark);
        text-decoration: none;
        letter-spacing: 1px;
        border-bottom: 1px solid var(--color-dark);
        padding-bottom: 3px;
        align-self: flex-start;
        display: inline-block;
    }

    .editor-quote-block {
        border-left: 3px solid var(--color-editorial-brown);
        padding-left: 20px;
        margin: 20px 0;
        transition: transform 0.4s ease, border-color 0.4s ease;
    }

        .editor-quote-block:hover {
            transform: translateX(5px);
            border-color: var(--color-goldaccent);
        }

    .serif-quote {
        font-family: var(--font-serif-header);
        font-size: 20px;
        font-style: italic;
        color: #8C847D;
        line-height: 1.6;
        margin-top: 15px;
    }

    .ecosystem-banner {
        background-color: #EAE6E1;
        padding: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 700;
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--color-editorial-brown);
        margin: 20px 0;
    }

    .banner-version {
        color: #BDB5AE;
    }

    /* ==========================================================================
           6. ANIMATIONS & EFFECTS (HIỆU ỨNG THÊM VÀO)
           ========================================================================== */

    /* Hiệu ứng Load trang cho Hero Section */
    @@keyframes fadeUpSlow {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-hero {
        animation: fadeUpSlow 1.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        opacity: 0;
    }

    .delay-1 {
        animation-delay: 0.2s;
    }

    .delay-2 {
        animation-delay: 0.5s;
    }

    /* Hiệu ứng Zoom ảnh nghệ thuật cực chậm */
    .grid-image {
        transition: transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .grid-item:hover .grid-image,
    .horiz-image:hover .grid-image,
    .sidebar-post:hover .grid-image,
    .podcast-img-wrapper:hover .side-card-img {
        transform: scale(1.05);
    }

    /* Hiệu ứng chữ và link khi Hover */
    .read-more-link, .read-more-link-small, .view-all-link {
        transition: all 0.4s ease;
    }

        .read-more-link:hover, .read-more-link-small:hover {
            color: var(--color-editorial-brown);
            letter-spacing: 3px; /* Kéo dãn chữ nhẹ */
            border-color: var(--color-editorial-brown);
        }

        .view-all-link:hover {
            color: var(--color-editorial-brown);
            transform: translateX(5px); /* Trượt sang phải */
        }

    /* Hiệu ứng Card Podcast */
    .podcast-card-side {
        transition: transform 0.4s ease, background-color 0.4s ease;
    }

        .podcast-card-side:hover {
            background-color: #ECE7E2;
            transform: translateX(8px);
            cursor: pointer;
        }

            .podcast-card-side:hover .card-title {
                color: var(--color-editorial-brown);
            }

    .sidebar-post:hover .serif-title-md {
        color: var(--color-editorial-brown);
    }
</style>

<header class="main-header"></header>

<div class="magazine-container">

    <main class="main-content-area">

        <div class="home-hero-section">
            <div class="hero-meta animate-hero delay-1">
                <span class="badge featured-badge">FEATURED EDITORIAL</span>
                <span class="issue-date">MAY 2024 ISSUE</span>
            </div>
            <h1 class="serif-title-xl animate-hero delay-2">Im lặng <br>là một ngôn từ.</h1>
        </div>

        <div class="grid-item large-post" data-aos="fade-up" data-aos-duration="1200">
            <a href="#">
                <img src="~/images/Home/GrayWall.png" alt="Water basin" class="grid-image" />
            </a>
            <div class="post-text-content">
                <h2 class="serif-title-lg">BẢN GIAO HƯỞNG CỦA NHỮNG NGÀY MƯA.</h2>
                <p class="article-excerpt">Khi tiếng mưa rơi hòa quyện cùng sự tĩnh lặng của căn phòng, ta bắt gặp chính mình trong những suy tư sâu thẳm nhất.</p>
                <a href="#" class="read-more-link">KHÁM PHÁ CHƯƠNG NÀY &rarr;</a>
            </div>
        </div>

        <div class="horizontal-post" data-aos="fade-up" data-aos-duration="1200" data-aos-offset="100">
            <a href="#" class="horiz-image">
                <img src="~/images/Home/Ghe.png" alt="Chair and branch" class="grid-image" />
            </a>
            <div class="horiz-text">
                <span class="section-title-sans">CẢM HỨNG HÀNG TUẦN</span>
                <h2 class="serif-title-md">CHẠM VÀO NHỮNG ĐIỀU BÌNH DỊ.</h2>
                <p class="article-excerpt">Hãy để tâm hồn mình được nghỉ ngơi sau những giờ làm việc căng thẳng. Đôi khi, chỉ cần một tách trà và một cuốn sách hay là quá đủ.</p>
                <a href="#" class="btn-outline">KHÁM PHÁ NGAY</a>
            </div>
        </div>

    </main>

    <aside class="sidebar-right-area">

        <h3 class="sans-header" data-aos="fade-in">ÂM THANH NGUYÊN BẢN</h3>

        <div class="podcast-card-side" data-aos="fade-left" data-aos-delay="100">
            <div class="podcast-img-wrapper">
                <img src="~/images/PodCast/podcast.png" alt="Podcast" class="side-card-img" />
            </div>
            <div class="side-card-info">
                <span class="tag-new">TẬP MỚI NHẤT</span>
                <h4 class="card-title serif-title">Chuyện về sự bao dung.</h4>
                <span class="duration">34:20 MIN</span>
            </div>
        </div>

        <div class="podcast-card-side" data-aos="fade-left" data-aos-delay="200">
            <div class="podcast-img-wrapper">
                <img src="~/images/PodCast/podcast.png" alt="Podcast" class="side-card-img" />
            </div>
            <div class="side-card-info">
                <span class="tag-new">TẬP MỚI NHẤT</span>
                <h4 class="card-title serif-title">Chuyện về sự bao dung.</h4>
                <span class="duration">34:20 MIN</span>
            </div>
        </div>

        <a href="#" class="view-all-link" data-aos="fade-in">TẤT CẢ PODCAST &rarr;</a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-post" data-aos="fade-up" data-aos-duration="1000">
            <a href="#">
                <img src="~/images/Order/galaxy.jpg" alt="Nebula" class="grid-image" />
            </a>
            <div class="post-meta">
                <span>27.05.2026</span> &bull; <span>771</span>
            </div>
            <h4 class="serif-title-md">NGHỆ THUẬT CỦA SỰ CHẬM RÃI</h4>
            <p class="article-excerpt-small">Trong một thế giới luôn hối hả, sự chậm rãi đôi khi bị coi là yếu đuối. Nhưng thực tế, chậm lại là c...</p>
            <a href="#" class="read-more-link-small">ĐỌC THÊM &rarr;</a>
        </div>

        <div class="sidebar-divider"></div>

        <div class="editor-quote-block" data-aos="fade-right">
            <span class="section-title-sans">GHI CHÉP TỪ BIÊN TẬP</span>
            <blockquote class="serif-quote">
                "Giữa thế giới ồn ào này, việc tìm thấy một khoảng lặng để lắng nghe chính mình là một món quà xa xỉ."
            </blockquote>
        </div>

        <div class="ecosystem-banner" data-aos="zoom-in">
            <span>HỆ SINH THÁI LẶNG</span>
            <span class="banner-version">v3.0</span>
        </div>

        <div class="sidebar-post" data-aos="fade-up" data-aos-duration="1000">
            <div class="badge chữa-lành-badge">TÂM SỰ</div>
            <a href="#">
                <img src="~/images/Home/Ghe.png" alt="Mountain" class="grid-image" />
            </a>
            <div class="post-meta">
                <span>07.06.2026</span> &bull; <span>80</span>
            </div>
            <h4 class="serif-title-md">TIẾNG VANG TRONG TĨNH LẶNG</h4>
            <p class="article-excerpt-small">Có những điều chỉ có thể nghe thấy khi ta hoàn toàn im lặng. Im lặng không phải là sự vắng mặt của â...</p>
            <a href="#" class="read-more-link-small">ĐỌC THÊM &rarr;</a>
        </div>

        <div class="sidebar-divider"></div>
        <a href="#" class="view-all-link" data-aos="fade-in">XEM THÊM CÂU CHUYỆN TỪ BẠN ĐỌC</a>

    </aside>

</div>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
    once: true,       // Hiệu ứng chỉ chạy 1 lần khi cuộn qua
    offset: 80,       // Kích hoạt hiệu ứng cách mép dưới màn hình 80px
    duration: 800,    // Tốc độ mượt mà mặc định
    easing: 'ease-out-cubic' // Gia tốc mềm mại
    });
</script>