@{
    ViewData["Title"] = "";
}
@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/Home/Index.css" />
@* ======================================================================================================================================================== *@



@* ======================================================================================================================================================== *@
<header class="main-header"></header>

<div class="magazine-container">

    <main class="main-content-area">

        <div class="home-hero-section">
            <div class="hero-meta animate-hero delay-1">
                <span class="badge featured-badge">FEATURED EDITORIAL</span>
                <span class="issue-date">MAY 2024 ISSUE</span>
            </div>
            <h1 class="serif-title-xl animate-hero delay-2">Im lặng <br>là một ngôn từ.</h1>
        </div>

        <div class="grid-item large-post" data-aos="fade-up" data-aos-duration="1200">
            <a href="#">
                <img src="~/images/Home/GrayWall.png" alt="Water basin" class="grid-image" />
            </a>
            <div class="post-text-content">
                <h2 class="serif-title-lg">BẢN GIAO HƯỞNG CỦA NHỮNG NGÀY MƯA.</h2>
                <p class="article-excerpt">Khi tiếng mưa rơi hòa quyện cùng sự tĩnh lặng của căn phòng, ta bắt gặp chính mình trong những suy tư sâu thẳm nhất.</p>
                <a href="#" class="read-more-link">KHÁM PHÁ CHƯƠNG NÀY &rarr;</a>
            </div>
        </div>

        <div class="horizontal-post" data-aos="fade-up" data-aos-duration="1200" data-aos-offset="100">
            <a href="#" class="horiz-image">
                <img src="~/images/Home/Ghe.png" alt="Chair and branch" class="grid-image" />
            </a>
            <div class="horiz-text">
                <span class="section-title-sans">CẢM HỨNG HÀNG TUẦN</span>
                <h2 class="serif-title-md">CHẠM VÀO NHỮNG ĐIỀU BÌNH DỊ.</h2>
                <p class="article-excerpt">Hãy để tâm hồn mình được nghỉ ngơi sau những giờ làm việc căng thẳng. Đôi khi, chỉ cần một tách trà và một cuốn sách hay là quá đủ.</p>
                <a href="#" class="btn-outline">KHÁM PHÁ NGAY</a>
            </div>
        </div>

    </main>

    <aside class="sidebar-right-area">

        <h3 class="sans-header" data-aos="fade-in">ÂM THANH NGUYÊN BẢN</h3>

        <div class="podcast-card-side" data-aos="fade-left" data-aos-delay="100">
            <div class="podcast-img-wrapper">
                <img src="~/images/PodCast/podcast.png" alt="Podcast" class="side-card-img" />
            </div>
            <div class="side-card-info">
                <span class="tag-new">TẬP MỚI NHẤT</span>
                <h4 class="card-title serif-title">Chuyện về sự bao dung.</h4>
                <span class="duration">34:20 MIN</span>
            </div>
        </div>

        <div class="podcast-card-side" data-aos="fade-left" data-aos-delay="200">
            <div class="podcast-img-wrapper">
                <img src="~/images/PodCast/podcast.png" alt="Podcast" class="side-card-img" />
            </div>
            <div class="side-card-info">
                <span class="tag-new">TẬP MỚI NHẤT</span>
                <h4 class="card-title serif-title">Chuyện về sự bao dung.</h4>
                <span class="duration">34:20 MIN</span>
            </div>
        </div>

        <a href="#" class="view-all-link" data-aos="fade-in">TẤT CẢ PODCAST &rarr;</a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-post" data-aos="fade-up" data-aos-duration="1000">
            <a href="#">
                <img src="~/images/Order/galaxy.jpg" alt="Nebula" class="grid-image" />
            </a>
            <div class="post-meta">
                <span>27.05.2026</span> &bull; <span>771</span>
            </div>
            <h4 class="serif-title-md">NGHỆ THUẬT CỦA SỰ CHẬM RÃI</h4>
            <p class="article-excerpt-small">Trong một thế giới luôn hối hả, sự chậm rãi đôi khi bị coi là yếu đuối. Nhưng thực tế, chậm lại là c...</p>
            <a href="#" class="read-more-link-small">ĐỌC THÊM &rarr;</a>
        </div>

        <div class="sidebar-divider"></div>

        <div class="editor-quote-block" data-aos="fade-right">
            <span class="section-title-sans">GHI CHÉP TỪ BIÊN TẬP</span>
            <blockquote class="serif-quote">
                "Giữa thế giới ồn ào này, việc tìm thấy một khoảng lặng để lắng nghe chính mình là một món quà xa xỉ."
            </blockquote>
        </div>

        <div class="ecosystem-banner" data-aos="zoom-in">
            <span>HỆ SINH THÁI LẶNG</span>
            <span class="banner-version">v3.0</span>
        </div>

        <div class="sidebar-post" data-aos="fade-up" data-aos-duration="1000">
            <div class="badge chữa-lành-badge">TÂM SỰ</div>
            <a href="#">
                <img src="~/images/Home/Ghe.png" alt="Mountain" class="grid-image" />
            </a>
            <div class="post-meta">
                <span>07.06.2026</span> &bull; <span>80</span>
            </div>
            <h4 class="serif-title-md">TIẾNG VANG TRONG TĨNH LẶNG</h4>
            <p class="article-excerpt-small">Có những điều chỉ có thể nghe thấy khi ta hoàn toàn im lặng. Im lặng không phải là sự vắng mặt của â...</p>
            <a href="#" class="read-more-link-small">ĐỌC THÊM &rarr;</a>
        </div>

        <div class="sidebar-divider"></div>
        <a href="#" class="view-all-link" data-aos="fade-in">XEM THÊM CÂU CHUYỆN TỪ BẠN ĐỌC</a>

    </aside>

</div>
@* ======================================================================================================================================================== *@




@* ======================================================================================================================================================== *@
@section Scripts {
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
    once: true,       // Hiệu ứng chỉ chạy 1 lần khi cuộn qua
    offset: 80,       // Kích hoạt hiệu ứng cách mép dưới màn hình 80px
    duration: 800,    // Tốc độ mượt mà mặc định
    easing: 'ease-out-cubic' // Gia tốc mềm mại
    });
</script>
}
@* ======================================================================================================================================================== *@



