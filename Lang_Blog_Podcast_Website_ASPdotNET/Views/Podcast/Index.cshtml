@model IEnumerable<Lang_Blog_Podcast_Website_ASPdotNET.Models.PodCast>

@{
    ViewData["Title"] = "Podcast - ";
}

@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Podcast/Index.css" asp-append-version="true" />
@* ======================================================================================================================================================== *@

<div class="lang-podcast-dark-container">
    @* --- HERO SECTION TỐI MỜ CAO CẤP --- *@
    <section class="podcast-hero">
        <div class="podcast-hero-background"></div>
        <div class="podcast-hero-overlay"></div>
        <div class="podcast-hero-content">
            <span class="hero-subtitle animate-hero" style="animation-delay: 0.1s">AUDIO SERIES</span>
            <h1 class="hero-title animate-hero" style="animation-delay: 0.3s">Sóng Âm Cảm Xúc.</h1>
            <p class="hero-desc animate-hero" style="animation-delay: 0.5s">
                Bật tai nghe lên, nhắm mắt lại và để những âm thanh dẫn lối bạn trở về với sự bình lặng sâu thẳm nhất. Một không gian của tạp chí LẶNG.
            </p>
            <div class="hero-actions animate-hero" style="animation-delay: 0.7s">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Podcast" asp-action="Submit" class="btn-primary-gold">
                        LAN TỎA TIẾNG NÓI CỦA BẠN
                    </a>
                }
                else
                {
                    <a href="javascript:void(0);" onclick="showLoginAlert()" class="btn-primary-gold">
                        LAN TỎA TIẾNG NÓI CỦA BẠN
                    </a>
                }
            </div>
        </div>
        <div class="hero-gradient-bottom"></div>
    </section>

    @* --- FILTER & SEARCH BAR GLASSMORPHISM --- *@
    <section class="podcast-toolbar">
        <form method="get" class="glass-filter-form" data-aos="fade-up" data-aos-duration="1000">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm kiếm tên tập, người dẫn..." class="glass-input" />
            </div>
            
            <div class="category-box">
                <select name="categoryId" class="glass-select" onchange="this.form.submit()">
                    <option value="">Tất cả chủ đề</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var category in ViewBag.Categories)
                        {
                            if (ViewBag.CategoryId == category.Id)
                            {
                                <option value="@category.Id" selected="selected">@category.Name</option>
                            }
                            else
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    }
                </select>
            </div>
            
            <div class="category-box">
                <select name="sortBy" class="glass-select" onchange="this.form.submit()">
                    @{
                        var currentSort = ViewBag.CurrentSort as string;
                    }
                    <option value="date_desc" selected="@(string.IsNullOrEmpty(currentSort) || currentSort == "date_desc" ? "selected" : null)">Sắp xếp: Mới nhất</option>
                    <option value="date_asc" selected="@(currentSort == "date_asc" ? "selected" : null)">Sắp xếp: Cũ nhất</option>
                    <option value="views_desc" selected="@(currentSort == "views_desc" ? "selected" : null)">Lượt xem: Cao đến thấp</option>
                    <option value="views_asc" selected="@(currentSort == "views_asc" ? "selected" : null)">Lượt xem: Thấp đến cao</option>
                    <option value="name_asc" selected="@(currentSort == "name_asc" ? "selected" : null)">Tên: A-Z</option>
                    <option value="name_desc" selected="@(currentSort == "name_desc" ? "selected" : null)">Tên: Z-A</option>
                </select>
            </div>

            <button type="submit" class="btn-glass-search">TÌM KIẾM</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search) || ViewBag.CategoryId != null || !string.IsNullOrEmpty(ViewBag.CurrentSort as string))
            {
                <a asp-controller="Podcast" asp-action="Index" class="btn-glass-clear" title="Xóa bộ lọc"><i class="fa-solid fa-xmark"></i></a>
            }
        </form>
    </section>

    @* --- PODCAST GRID CAO CẤP --- *@
    <section class="podcast-grid-section">
        <div class="podcast-grid">
            @if (Model != null && Model.Any())
            {
                int delay = 0;
                foreach (var podcast in Model)
                {
                    <div class="premium-podcast-card" data-aos="fade-up" data-aos-duration="1200" data-aos-delay="@delay"
                         data-audio-url="@podcast.AudioPath"
                         data-audio-title="@podcast.Title"
                         data-audio-author="@(podcast.User?.FullName ?? podcast.Author ?? "Lặng")"
                         data-audio-image="@podcast.ImagePath"
                         data-podcast-id="@podcast.Id">
                        
                        <a asp-controller="Podcast" asp-action="Details" asp-route-id="@podcast.Id" class="card-link-wrapper">
                            @* Nửa trên: Ảnh bìa cinematic *@
                            <div class="card-image-section">
                                <img src="@podcast.ImagePath" class="card-image" alt="@podcast.Title" />
                                <div class="card-image-overlay"></div>
                                <span class="card-badge">@(podcast.Category?.Name ?? "Podcast")</span>
                                
                                @* Nút play lอย giữa ảnh bìa khi hover *@
                                <div class="card-play-button" onclick="event.preventDefault(); event.stopPropagation(); playFromCard(this);">
                                    <div class="play-btn-circle">
                                        <i class="fa-solid fa-play"></i>
                                    </div>
                                </div>
                            </div>

                            @* Nửa dưới: Thông tin *@
                            <div class="card-info-section">
                                <div class="card-meta">
                                    @{
                                        var cardAuthor = podcast.User?.FullName ?? podcast.Author ?? "Lặng";
                                        var displayCardAuthor = cardAuthor.Length > 15 ? cardAuthor.Substring(0, 15) + "..." : cardAuthor;
                                    }
                                    <span class="meta-item" title="@cardAuthor">
                                        <i class="fa-solid fa-microphone"></i> @displayCardAuthor
                                    </span>
                                    <span class="meta-dot"></span>
                                    <span class="meta-item">@(podcast.EpisodeNumber.HasValue ? "Tập " + podcast.EpisodeNumber : "Mới")</span>
                                    @if (!string.IsNullOrEmpty(podcast.Duration))
                                    {
                                        <span class="meta-dot"></span>
                                        <span class="meta-item"><i class="fa-regular fa-clock"></i> @podcast.Duration</span>
                                    }
                                </div>

                                <h3 class="card-title">
                                    @(podcast.Title.Length > 40 ? podcast.Title.Substring(0, 40) + "..." : podcast.Title)
                                </h3>

                                <p class="card-desc">
                                    @(podcast.Description?.Length > 75 ? podcast.Description.Substring(0, 75) + "..." : podcast.Description)
                                </p>

                                <div class="card-footer">
                                    <div class="footer-left">
                                        <span class="card-date">@((podcast.PublishDate ?? podcast.CreatedAt).ToString("dd/MM/yyyy"))</span>
                                        <span class="meta-dot"></span>
                                        <span class="card-views" title="Lượt xem"><i class="fa-regular fa-eye"></i> @podcast.ViewCount</span>
                                    </div>
                                    <span class="card-action-text">CHI TIẾT <i class="fa-solid fa-arrow-right"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                    delay += 100;
                    if (delay > 400) delay = 0; // Tránh delay quá lâu cho các item sau
                }
            }
            else
            {
                <div class="empty-state" data-aos="fade-up">
                    <i class="fa-solid fa-headphones empty-icon"></i>
                    <p>Hiện tại chưa có Podcast nào được phát sóng.</p>
                </div>
            }
        </div>

        @* --- PHÂN TRANG --- *@
        @{
            int currentPage = ViewBag.CurrentPage ?? 1;
            int totalPages = ViewBag.TotalPages ?? 1;
        }
        @if (totalPages > 1)
        {
            <nav class="pagination-nav" data-aos="fade-up">
                <a class="page-link @(currentPage <= 1 ? "disabled" : "")"
                   href="@Url.Action("Index", "Podcast", new { search = ViewBag.Search, categoryId = ViewBag.CategoryId, sortBy = ViewBag.CurrentSort, page = currentPage - 1 })">
                    <i class="fa-solid fa-chevron-left"></i>
                </a>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <a class="page-link @(i == currentPage ? "active" : "")"
                       href="@Url.Action("Index", "Podcast", new { search = ViewBag.Search, categoryId = ViewBag.CategoryId, sortBy = ViewBag.CurrentSort, page = i })">
                        @i
                    </a>
                }

                <a class="page-link @(currentPage >= totalPages ? "disabled" : "")"
                   href="@Url.Action("Index", "Podcast", new { search = ViewBag.Search, categoryId = ViewBag.CategoryId, sortBy = ViewBag.CurrentSort, page = currentPage + 1 })">
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            </nav>
        }
    </section>
</div>

@section Scripts {
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Init Animate On Scroll
    AOS.init({
        once: true,
        offset: 50,
        easing: 'ease-out-cubic'
    });

    function showLoginAlert() {
        Swal.fire({
            title: 'Một chút nhịp ngưng...',
            text: 'Bạn cần đăng nhập để có thể gửi gắm câu chuyện của mình. Hãy đăng nhập và trở lại đây nhé!',
            icon: 'info',
            showCancelButton: true,
            confirmButtonColor: '#B29B84',
            cancelButtonColor: '#2A2825',
            confirmButtonText: 'Đăng nhập',
            cancelButtonText: 'Lúc khác',
            background: '#1A1817',
            color: '#F5F1EE',
            customClass: {
                popup: 'dark-swal-popup'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Identity/Account/Login';
            }
        });
    }

    // Hàm phát nhạc từ Podcast Card qua Global Player
    function playFromCard(btnEl) {
        var card = btnEl.closest('.premium-podcast-card');
        if (!card) return;
        var audioUrl = card.getAttribute('data-audio-url');
        var title = card.getAttribute('data-audio-title');
        var author = card.getAttribute('data-audio-author');
        var image = card.getAttribute('data-audio-image');
        var podcastId = card.getAttribute('data-podcast-id');
        
        // Thêm hiệu ứng nút scale up khi click
        btnEl.classList.add('is-clicked');
        setTimeout(() => btnEl.classList.remove('is-clicked'), 300);

        if (typeof LangPlayer !== 'undefined') {
            LangPlayer.play(audioUrl, title, author, image, podcastId);
        }
    }
</script>
}