@{
    ViewData["Title"] = "";
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Podcast/Index.css" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="lang-podcast-container">
    <header class="podcast-header">
        <div class="podcast-header-bg-text">AUDIO</div>
        <div style="position: relative; z-index: 2;">
            <span class="podcast-header-sub animate-podcast-text p-delay-1">Sóng âm cảm xúc</span>
            <h1 class="podcast-header-title animate-podcast-text p-delay-2">Podcast Series.</h1>
            <p class="podcast-header-desc animate-podcast-text p-delay-3">
                Bật tai nghe lên, nhắm mắt lại và để những âm thanh dẫn lối bạn trở về với sự bình lặng sâu thẳm nhất.
            </p>
        </div>
    </header>

    <div class="podcast-grid">
        @for (int i = 1; i <= 4; i++)
        {
            <div class="podcast-card" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="@((i - 1) * 150)">
                <div class="podcast-img-wrapper">
                    <img src="~/images/Logo/logo_website.png" class="podcast-img" alt="Podcast Cover" />

                    <div class="podcast-play-overlay">
                        <div class="play-btn-circle">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#ffffff" stroke="#ffffff" stroke-width="2" style="transform: translateX(1px);">
                                <polygon points="6 3 20 12 6 21 6 3"></polygon>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="podcast-info">
                    <div class="podcast-meta">
                        <span>Mùa 01 • Tập @i</span>
                        <span class="podcast-dot"></span>
                        <span style="opacity: 0.7;">45:00</span>
                    </div>

                    <h3 class="podcast-title">
                        Về những ngày mưa và tách trà nóng nghi ngút khói.
                    </h3>

                    <p class="podcast-desc">
                        Những ngày mưa thường gợi cho chúng ta nhiều kỷ niệm khó quên, có lẽ vì tiếng mưa rơi luôn làm lòng ta dịu lại giữa nhịp sống hối hả...
                    </p>

                    <div class="podcast-action">
                        NGHE NGAY <span class="podcast-line"></span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
@section Scripts {
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
    once: true,             // Hiệu ứng chỉ kích hoạt 1 lần duy nhất khi cuộn tới
    offset: 80,             // Điểm kích hoạt cách mép dưới màn hình 80px
    easing: 'ease-out-cubic'// Gia tốc chuyển động mềm mại
    });
</script>
}
@* ======================================================================================================================================================== *@