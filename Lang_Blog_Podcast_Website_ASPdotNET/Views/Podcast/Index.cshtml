@{
    ViewData["Title"] = "Podcast - Lặng";
}

<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

<style>
    /* Khởi tạo biến màu sắc đồng bộ hệ sinh thái Lặng. */
    :root {
        --bg-cream: #F4F1EA; /* Màu nền kem đặc trưng */
        --bg-white: #FFFFFF;
        --primary-deep: #2A2825; /* Màu nâu đen trầm lắng */
        --primary-soft: #8C8275; /* Màu chữ phụ, nhãn tập */
        --border-color: #E2DDD5; /* Đường kẻ mảnh tinh tế */
    }

    .lang-podcast-container {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-cream);
        color: var(--primary-deep);
        min-height: 100vh;
        padding-bottom: 60px;
        overflow-x: hidden; /* Ngăn hiện tượng vỡ khung khi chạy hiệu ứng */
    }

    /* Vùng Header tối */
    .podcast-header {
        background-color: var(--primary-deep);
        color: var(--bg-cream);
        padding: 100px 20px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    /* --- HIỆU ỨNG TRÔI NỔI CHẬM CHO CHỮ AUDIO --- */
    @@keyframes audioFloat {
        0% {
            transform: rotate(-8deg) scale(1) translateY(0);
        }

        50% {
            transform: rotate(-6deg) scale(1.02) translateY(-10px);
        }

        100% {
            transform: rotate(-8deg) scale(1) translateY(0);
        }
    }

    .podcast-header-bg-text {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display', serif;
        font-size: 16vw;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--bg-cream);
        opacity: 0.03;
        transform: rotate(-8deg);
        pointer-events: none;
        user-select: none;
        animation: audioFloat 15s ease-in-out infinite; /* Chuyển động lặp vô tận */
    }

    /* --- HIỆU ỨNG HIỆN CHỮ THANH THOÁT --- */
    @@keyframes fadeUpText {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-podcast-text {
        opacity: 0;
        animation: fadeUpText 1.4s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    .p-delay-1 {
        animation-delay: 0.2s;
    }

    .p-delay-2 {
        animation-delay: 0.4s;
    }

    .p-delay-3 {
        animation-delay: 0.6s;
    }

    .podcast-header-sub {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5em;
        margin-bottom: 20px;
        display: block;
        opacity: 0.6;
    }

    .podcast-header-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-style: italic;
        font-weight: 400;
        margin-bottom: 24px;
    }

    .podcast-header-desc {
        max-width: 500px;
        margin: 0 auto;
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.7;
        opacity: 0.7;
    }

    /* Danh sách hiển thị dạng lưới 2 cột */
    .podcast-grid {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 20px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
    }

    @@media (min-width: 768px) {
        .podcast-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }
    }

    /* Khối thẻ từng tập Podcast */
    .podcast-card {
        background-color: var(--bg-white);
        border: 1px solid var(--border-color);
        padding: 30px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        transition: background-color 0.5s ease, border-color 0.5s ease, transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.5s ease;
        cursor: pointer;
    }

    @@media (min-width: 576px) {
        .podcast-card {
            flex-direction: row;
        }
    }

    .podcast-card:hover {
        background-color: #ECE8DE;
        border-color: var(--primary-soft);
        transform: translateY(-5px); /* Nhấc nhẹ thẻ lên cao hơn */
        box-shadow: 0 15px 35px rgba(42, 40, 37, 0.04);
    }

    /* Phần ảnh bìa tập */
    .podcast-img-wrapper {
        width: 100%;
        aspect-ratio: 1 / 1;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--border-color);
        flex-shrink: 0;
    }

    @@media (min-width: 576px) {
        .podcast-img-wrapper {
            width: 160px;
        }
    }

    .podcast-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(100%);
        transition: filter 0.8s ease, transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .podcast-card:hover .podcast-img {
        filter: grayscale(0%);
        transform: scale(1.06); /* Phóng nhẹ ảnh bìa nghệ thuật */
    }

    /* Nút bấm Play hiển thị khi hover */
    .podcast-play-overlay {
        position: absolute;
        inset: 0;
        background: rgba(42, 40, 37, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .podcast-card:hover .podcast-play-overlay {
        opacity: 1;
    }

    .play-btn-circle {
        width: 50px;
        height: 50px;
        border: 2px solid var(--bg-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(42, 40, 37, 0.2);
        transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.3s ease;
    }

    .podcast-card:hover .play-btn-circle {
        transform: scale(1.08); /* Phóng to nhẹ vòng tròn Play */
        background-color: var(--primary-deep);
        border-color: var(--primary-deep);
    }

    /* Phần nội dung chữ */
    .podcast-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .podcast-meta {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--primary-soft);
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .podcast-dot {
        width: 4px;
        height: 4px;
        background-color: var(--primary-soft);
        border-radius: 50%;
        display: inline-block;
    }

    .podcast-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 400;
        line-height: 1.4;
        color: var(--primary-deep);
        margin: 0 0 12px 0;
        transition: color 0.3s ease;
    }

    .podcast-desc {
        font-size: 0.85rem;
        line-height: 1.6;
        color: #6E6861;
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .podcast-action {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: auto;
    }

    .podcast-line {
        width: 30px;
        height: 1px;
        background-color: var(--primary-deep);
        display: inline-block;
        transition: width 0.4s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.4s ease;
    }

    .podcast-card:hover .podcast-line {
        width: 50px; /* Kéo dài thanh ngang mượt mà */
    }
</style>

<div class="lang-podcast-container">
    <header class="podcast-header">
        <div class="podcast-header-bg-text">AUDIO</div>
        <div style="position: relative; z-index: 2;">
            <span class="podcast-header-sub animate-podcast-text p-delay-1">Sóng âm cảm xúc</span>
            <h1 class="podcast-header-title animate-podcast-text p-delay-2">Podcast Series.</h1>
            <p class="podcast-header-desc animate-podcast-text p-delay-3">
                Bật tai nghe lên, nhắm mắt lại và để những âm thanh dẫn lối bạn trở về với sự bình lặng sâu thẳm nhất.
            </p>
        </div>
    </header>

    <div class="podcast-grid">
        @for (int i = 1; i <= 4; i++)
        {
            <div class="podcast-card" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="@((i - 1) * 150)">
                <div class="podcast-img-wrapper">
                    <img src="~/images/logo_website.png" class="podcast-img" alt="Podcast Cover" />

                    <div class="podcast-play-overlay">
                        <div class="play-btn-circle">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#ffffff" stroke="#ffffff" stroke-width="2" style="transform: translateX(1px);">
                                <polygon points="6 3 20 12 6 21 6 3"></polygon>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="podcast-info">
                    <div class="podcast-meta">
                        <span>Mùa 01 • Tập @i</span>
                        <span class="podcast-dot"></span>
                        <span style="opacity: 0.7;">45:00</span>
                    </div>

                    <h3 class="podcast-title">
                        Về những ngày mưa và tách trà nóng nghi ngút khói.
                    </h3>

                    <p class="podcast-desc">
                        Những ngày mưa thường gợi cho chúng ta nhiều kỷ niệm khó quên, có lẽ vì tiếng mưa rơi luôn làm lòng ta dịu lại giữa nhịp sống hối hả...
                    </p>

                    <div class="podcast-action">
                        NGHE NGAY <span class="podcast-line"></span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
    once: true,             // Hiệu ứng chỉ kích hoạt 1 lần duy nhất khi cuộn tới
    offset: 80,             // Điểm kích hoạt cách mép dưới màn hình 80px
    easing: 'ease-out-cubic'// Gia tốc chuyển động mềm mại
    });
</script>