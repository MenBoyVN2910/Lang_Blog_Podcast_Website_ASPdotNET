@using System.Text.RegularExpressions
@model IEnumerable<Lang_Blog_Podcast_Website_ASPdotNET.Models.Story>

@{
    ViewData["Title"] = "Câu chuyện - ";
}

@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Story/Index.css" asp-append-version="true" />
@* ======================================================================================================================================================== *@

<div class="lang-story-light-container">
    @* --- HERO SECTION (LIGHT EDITORIAL) --- *@
    <section class="story-hero">
        <div class="story-hero-background"></div>
        <div class="story-hero-content">
            <div class="header-badge-group animate-hero" style="animation-delay: 0.1s">
                <i class="fa-solid fa-feather-pointed badge-icon"></i>
                <span class="header-badge-text">Cộng đồng của sự sẻ chia</span>
            </div>

            <h1 class="hero-title animate-hero" style="animation-delay: 0.3s">
                Mảnh ghép <br />
                <span class="italic">Ký ức.</span>
            </h1>

            <p class="hero-desc animate-hero" style="animation-delay: 0.5s">
                "Mỗi câu chuyện bạn gửi đi là một nhịp cầu nối liền những tâm hồn cô đơn. Hãy để tiếng lòng của bạn được lắng nghe tại đây."
            </p>

            <div class="hero-actions animate-hero" style="animation-delay: 0.7s">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Story" asp-action="Submit" class="btn-primary-dark">
                        GỬI CÂU CHUYỆN CỦA BẠN
                    </a>
                }
                else
                {
                    <a href="javascript:void(0);" onclick="showLoginAlert()" class="btn-primary-dark">
                        GỬI CÂU CHUYỆN CỦA BẠN
                    </a>
                }
            </div>
        </div>
    </section>

    @* --- LIGHT GLASSMORPHISM FILTER BAR --- *@
    <section class="story-toolbar">
        <form asp-action="Index" method="get" class="glass-filter-form" data-aos="fade-up" data-aos-duration="1000">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" placeholder="Tìm kiếm tên câu chuyện..." class="glass-input" />
            </div>

            <div class="category-box">
                <select name="categoryId" class="glass-select" onchange="this.form.submit()">
                    <option value="">Tất cả danh mục</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            if (ViewBag.CurrentCategoryId == cat.Id)
                            {
                                <option value="@cat.Id" selected="selected">@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn-glass-search">TÌM KIẾM</button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch) || ViewBag.CurrentCategoryId != null)
            {
                <a asp-controller="Story" asp-action="Index" class="btn-glass-clear" title="Xóa bộ lọc"><i class="fa-solid fa-xmark"></i></a>
            }
        </form>
    </section>

    @* --- STORY GRID CAO CẤP --- *@
    <section class="story-grid-section">
        <div class="story-grid">
            @{
                // Lọc ra danh sách các bài viết đã được duyệt
                var approvedStories = Model.Where(s => s.Status == StoryStatus.Approved).ToList();
            }

            @if (!approvedStories.Any())
            {
                <div class="empty-state" data-aos="fade-up">
                    <i class="fa-solid fa-book-open empty-icon"></i>
                    <p>Hiện tại chưa có câu chuyện nào trong mục này. Hãy là người đầu tiên chia sẻ nhé!</p>
                </div>
            }
            else
            {
                int delay = 0;
                foreach (var story in approvedStories)
                {
                    // Lọc HTML tags để hiển thị trích dẫn
                    var plainText = string.IsNullOrEmpty(story.Content) ? "" : System.Text.RegularExpressions.Regex.Replace(story.Content, "<.*?>", string.Empty);
                    var excerpt = plainText.Length > 120 ? plainText.Substring(0, 120) + "..." : plainText;

                    // Fallback ảnh mặc định
                    var defaultImg = string.IsNullOrWhiteSpace(story.ImagePath) ? Url.Content("~/images/Default_Images/Blog.png") : story.ImagePath;

                    <div class="premium-story-card" data-aos="fade-up" data-aos-duration="1200" data-aos-delay="@delay">
                        <a href="@Url.Action("Details", "Story", new { id = story.Id })" class="card-link-wrapper">
                            
                            @* Nửa trên: Ảnh bìa cinematic 16:10 *@
                            <div class="card-image-section">
                                <img src="@defaultImg" class="card-image" alt="@story.Title" />
                                <div class="card-image-overlay"></div>
                                <span class="card-badge">@(story.Category?.Name ?? "Tâm sự")</span>
                            </div>

                            @* Nửa dưới: Thông tin bài viết *@
                            <div class="card-info-section">
                                <div class="card-meta">
                                    @{
                                        var rawAuthor = string.IsNullOrEmpty(story.User?.FullName) ? (string.IsNullOrEmpty(story.Author) ? "Ẩn danh" : story.Author) : story.User.FullName;
                                        var displayAuthor = rawAuthor.Length > 15 ? rawAuthor.Substring(0, 15) + "..." : rawAuthor;
                                    }
                                    <span class="meta-item">@story.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    <span class="meta-dot"></span>
                                    <span class="meta-item" title="@rawAuthor"><i class="fa-solid fa-pen-nib" style="margin-right: 4px; font-size: 10px;"></i>@displayAuthor</span>
                                    <span class="meta-dot"></span>
                                    <span class="meta-item">@(string.IsNullOrEmpty(story.IssueNumber) ? "Mới" : story.IssueNumber)</span>
                                </div>

                                <h3 class="card-title">
                                    @(story.Title?.Length > 40 ? story.Title.Substring(0, 40) + "..." : story.Title)
                                </h3>

                                <p class="card-excerpt">
                                    @Html.Raw(excerpt)
                                </p>

                                <div class="card-views-container">
                                    <span class="card-views" title="Lượt xem"><i class="fa-regular fa-eye"></i> @story.ViewCount</span>
                                </div>

                                <div class="card-footer">
                                    <span class="card-action-text">ĐỌC THÊM <i class="fa-solid fa-arrow-right"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                    delay += 100;
                    if (delay > 400) delay = 0; // Tránh delay quá lâu
                }
            }
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        AOS.init({
            once: true,
            offset: 50,
            easing: 'ease-out-cubic'
        });

        function showLoginAlert() {
            Swal.fire({
                title: 'Một chút nhịp ngưng...',
                text: 'Bạn cần đăng nhập để có thể gửi gắm câu chuyện của mình. Hãy đăng nhập và trở lại đây nhé!',
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#2A2825',
                cancelButtonColor: '#E2DDD5',
                confirmButtonText: 'Đăng nhập',
                cancelButtonText: 'Lúc khác',
                background: '#FAF9F6',
                color: '#2A2825',
                customClass: {
                    popup: 'light-swal-popup'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Identity/Account/Login';
                }
            });
        }
    </script>
}