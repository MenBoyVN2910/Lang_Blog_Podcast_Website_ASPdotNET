@model Lang_Blog_Podcast_Website_ASPdotNET.Models.Story

@{
    ViewData["Title"] = Model.Title;
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="~/css/Story/detail.css" asp-append-version="true" />\
<!-- Thêm version (hash) vào URL của file CSS để tránh trình duyệt dùng cache cũ.
     Khi file thay đổi, URL cũng thay đổi và trình duyệt sẽ tải phiên bản mới. -->
@* ======================================================================================================================================================== *@



@* ======================================================================================================================================================== *@
<div class="lang-story-light-container">
    <div class="article-container">
        <div class="custom-editorial-layout">

            <!-- CỘT TRÁI: SIDEBAR THÔNG TIN -->
            <div class="sidebar-column">
                <div class="sidebar-meta">
                    <a href="@Url.Action("Index", "Story")" class="back-link">
                        <i class="fa-solid fa-arrow-left" style="margin-right: 8px;"></i> QUAY LẠI CÂU CHUYỆN
                    </a>

                    <div class="meta-group">
                        <span class="meta-label">DANH MỤC</span>
                        <span class="meta-value font-italic">@(Model.Category?.Name ?? "Tâm sự")</span>
                    </div>

                    <div class="meta-group">
                        <span class="meta-label">NGÀY XUẤT BẢN</span>
                        <span class="meta-value">@Model.CreatedAt.ToString("dd.MM.yyyy")</span>
                    </div>

                    

                    <div class="meta-group">
                        <span class="meta-label">SỐ PHÁT HÀNH</span>
                        <span class="meta-value font-italic">@(string.IsNullOrEmpty(Model.IssueNumber) ? "None" : Model.IssueNumber)</span>
                    </div>

                    <div class="meta-group">
                        <span class="meta-label">TÁC GIẢ</span>
                        @{
                            var rawAuthor = Model.User?.FullName ?? "Ẩn danh";
                            var displayAuthor = rawAuthor.Length > 20 ? rawAuthor.Substring(0, 20) + "..." : rawAuthor;
                            var authorUsername = Model.User?.UserName;
                        }
                        @if (authorUsername != null)
                        {
                            <a href="@Url.Action("Index", "Profile", new { username = authorUsername })"
                               class="meta-value font-italic author-link"
                               title="Xem trang cá nhân của @rawAuthor">@displayAuthor</a>
                        }
                        else
                        {
                            <span class="meta-value font-italic" title="@rawAuthor">@displayAuthor</span>
                        }
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI: NỘI DUNG CHÍNH -->
            <div class="content-column">
                <div class="article-header">
                    <span class="category-badge">@(Model.Category?.Name?.ToUpper() ?? "TÂM SỰ")</span>
                    <h1 class="article-title">@Model.Title</h1>
                </div>

                <!-- NỘI DUNG CHỮ CHẠY LIỀN MẠCH NGAY DƯỚI TIÊU ĐỀ -->
                <div class="article-body">
                    @Html.Raw(Model.Content)
                </div>

                <div class="article-divider"></div>

                <!-- FOOTER BÀI VIẾT -->
                <div class="article-footer">
                    <div class="author-note">
                        <span class="note-label">LỜI NGỎ</span>
                        <p>Cảm ơn bạn đã dành thời gian lắng nghe tâm hồn của Lặnger.<br>Hy vọng bài viết này mang lại cho bạn chút ánh sáng nhỏ bé<br>trong thế giới đầy hối hả này.</p>
                    </div>
                    <div class="magazine-signature">
                        <span class="note-label">NGƯỜI HỖ TRỢ</span>
                        <h4>Lặng.Story</h4>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
@* ======================================================================================================================================================== *@