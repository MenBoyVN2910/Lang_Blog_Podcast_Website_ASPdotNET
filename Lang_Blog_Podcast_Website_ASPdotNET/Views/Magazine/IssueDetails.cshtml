@model Lang_Blog_Podcast_Website_ASPdotNET.Models.MagazineIssue
@using System.Text.RegularExpressions

@{
    ViewData["Title"] = Model.Title;
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="~/css/Magazine/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Magazine/IssueDetails.css" asp-append-version="true" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="lang-magazine-avant-container">
    
    <div style="padding: 20px 40px;">
        <a href="/Magazine" style="color: #000; text-decoration: none; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 14px; letter-spacing: 1px;">
            <i class="fa-solid fa-arrow-left"></i> TRỞ VỀ KỆ TẠP CHÍ
        </a>
    </div>

    <div class="flipbook-wrapper">
        <div id="flipbook" class="flipbook">
            
            <!-- Trang bìa cứng (Cover) -->
            <div class="page hard">
                <div class="cover-page">
                    <img src="@Model.CoverImagePath" alt="Cover" />
                    <div class="cover-text">
                        <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; letter-spacing: 4px; margin-bottom: 20px;">@Model.IssueNumber</div>
                        <h1>@Model.Title</h1>
                        <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 12px; letter-spacing: 2px; margin-top: 40px; text-transform: uppercase;">
                            @Model.Season
                        </div>
                    </div>
                </div>
            </div>

            <!-- Lời tựa (Trang trong 1) -->
            <div class="page">
                <div class="page-content" style="justify-content: center; text-align: center;">
                    <h3 style="font-family: var(--font-serif-header); font-size: 24px; margin-bottom: 30px;">Lời Tựa</h3>
                    <p style="font-family: var(--font-serif-body); font-size: 16px; line-height: 2; font-style: italic; color: #555; padding: 0 30px;">
                        "@Model.Description"
                    </p>
                    <div style="margin-top: 40px; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; letter-spacing: 2px; font-size: 12px;">
                        - THE EDITOR -
                    </div>
                </div>
            </div>

            <!-- Các bài viết -->
            @if(Model.Articles != null)
            {
                foreach(var article in Model.Articles)
                {
                    string plainText = string.IsNullOrEmpty(article.Content) ? "" : Regex.Replace(article.Content, "<.*?>", string.Empty);
                    string excerpt = plainText.Length > 400 ? plainText.Substring(0, 400) + "..." : plainText;

                    <div class="page article-page">
                        <div class="page-content">
                            <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 10px; color: #999; letter-spacing: 2px; margin-bottom: 15px; text-transform: uppercase;">
                                @(article.Category?.Name ?? "Editorial")
                            </div>
                            
                            <h2>@article.Title</h2>
                            <img src="@article.ImagePath" alt="@article.Title" />
                            
                            <div class="excerpt">
                                @Html.Raw(excerpt)
                            </div>
                            
                            <div style="text-align: right; margin-top: auto;">
                                <a href="/Magazine/ArticleDetails/@article.Id" class="read-more-btn">Đọc Toàn Bộ Bài Viết</a>
                            </div>
                        </div>
                    </div>
                }
            }

            <!-- Bìa sau (Back cover) -->
            <div class="page hard">
                <div style="background-color: #111; height: 100%; display: flex; align-items: center; justify-content: center; color: #fff; flex-direction: column;">
                    <div style="font-family: var(--font-serif-header); font-size: 30px; letter-spacing: 5px;">LẶNG.</div>
                    <div style="margin-top: 20px; width: 50px; height: 1px; background: #fff;"></div>
                    <div style="margin-top: 20px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 10px; letter-spacing: 3px;">END OF ISSUE</div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="flip-nav">
        <button id="btn-prev"><i class="fa-solid fa-chevron-left"></i> Lật trang trước</button>
        <span id="page-counter" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; margin: 0 15px;"></span>
        <button id="btn-next">Lật trang sau <i class="fa-solid fa-chevron-right"></i></button>
    </div>
</div>
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
@section Scripts {
    <!-- StPageFlip (Vanilla JS library cho hiệu ứng lật trang HTML5 3D) -->
    <script src="https://cdn.jsdelivr.net/npm/page-flip/dist/js/page-flip.browser.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Khởi tạo PageFlip
            const pageFlip = new St.PageFlip(document.getElementById('flipbook'), {
                width: 450, // width base cho 1 trang (không phải cả cuốn sách)
                height: 600,
                size: "stretch",
                minWidth: 315,
                maxWidth: 1000,
                minHeight: 420,
                maxHeight: 1350,
                drawShadow: true,
                showCover: true,
                mobileScrollSupport: false // Vô hiệu hóa vuốt cuộn trên đt để tránh xung đột
            });

            // Tải trang từ DOM
            pageFlip.loadFromHTML(document.querySelectorAll('.page'));

            // Controls
            document.getElementById('btn-prev').addEventListener('click', () => {
                pageFlip.flipPrev();
            });

            document.getElementById('btn-next').addEventListener('click', () => {
                pageFlip.flipNext();
            });

            // Cập nhật trạng thái số trang
            pageFlip.on('flip', (e) => {
                // e.data là trang đang được lật tới (trang đầu của mảng hiển thị)
                const totalPages = pageFlip.getPageCount();
                document.getElementById('page-counter').innerText = `${e.data + 1} / ${totalPages}`;
            });

            // Gán số trang khởi tạo
            document.getElementById('page-counter').innerText = `1 / ${document.querySelectorAll('.page').length}`;
        });
    </script>
}
@* ======================================================================================================================================================== *@