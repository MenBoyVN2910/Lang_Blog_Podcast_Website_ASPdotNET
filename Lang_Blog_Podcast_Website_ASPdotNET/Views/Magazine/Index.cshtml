@model IEnumerable<Lang_Blog_Podcast_Website_ASPdotNET.Models.MagazineIssue>

@{
    ViewData["Title"] = "Tạp Chí - Kệ Ấn Phẩm";
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Magazine/Index.css" asp-append-version="true" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="lang-magazine-avant-container">
    
    @* --- AVANT-GARDE HEADER --- *@
    <header class="magazine-hero">
        <div class="hero-watermark">EDITORIAL</div>
        
        <div class="hero-content">
            <h1 class="hero-title animate-mag m-delay-2" style="font-size: 8vw;">
                <span class="title-main">LẶNG.</span><br />
                <span class="title-sub">MAGAZINE</span>
            </h1>

            <div class="hero-bottom-grid animate-mag m-delay-3">
                <div class="hero-quote">
                    "Tập san của những tâm hồn đồng điệu. Chọn một ấn phẩm và thả mình vào sự tĩnh lặng."
                </div>
            </div>
        </div>
    </header>

    @* --- MAGAZINE SHELF (Kệ tạp chí) --- *@
    <main class="magazine-body" style="max-width: 1400px; margin: 0 auto; padding: 0 40px 100px 40px;">
        @if (!Model.Any())
        {
            <div style="text-align: center; padding: 100px 0;">
                <h3 style="font-family: var(--font-serif-header); color: #ccc; font-size: 24px; letter-spacing: 2px;">HIỆN CHƯA CÓ ẤN PHẨM NÀO ĐƯỢC PHÁT HÀNH.</h3>
            </div>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 50px;">
                @foreach (var issue in Model)
                {
                    <article data-aos="fade-up" data-aos-duration="1000">
                        <a href="/Magazine/IssueDetails/@issue.Id" style="text-decoration: none; color: inherit; display: block; group;">
                            <div style="position: relative; overflow: hidden; border: 1px solid #000; box-shadow: 15px 15px 0px #000; transition: transform 0.3s ease, box-shadow 0.3s ease;" 
                                 onmouseover="this.style.transform='translate(-5px, -5px)'; this.style.boxShadow='20px 20px 0px #000';"
                                 onmouseout="this.style.transform='translate(0, 0)'; this.style.boxShadow='15px 15px 0px #000';">
                                
                                <img src="@issue.CoverImagePath" alt="@issue.Title" style="width: 100%; aspect-ratio: 3/4; object-fit: cover; filter: grayscale(100%); transition: filter 0.5s ease;"
                                     onmouseover="this.style.filter='grayscale(0%)';" onmouseout="this.style.filter='grayscale(100%)';" />
                                
                                <div style="position: absolute; top: 15px; left: 15px; background: #000; color: #fff; padding: 5px 10px; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 2px;">
                                    @issue.IssueNumber
                                </div>
                            </div>

                            <div style="margin-top: 25px; border-top: 2px solid #000; padding-top: 15px;">
                                <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: #888; margin-bottom: 8px; text-transform: uppercase;">
                                    @issue.Season &mdash; @(issue.PublishDate?.ToString("MM/yyyy"))
                                </div>
                                <h2 style="font-family: var(--font-serif-header); font-size: 28px; line-height: 1.2; margin: 0; color: #000;">
                                    @issue.Title
                                </h2>
                                <p style="font-family: var(--font-sans); font-size: 14px; color: #555; margin-top: 10px; line-height: 1.6;">
                                    @issue.Description
                                </p>
                            </div>
                        </a>
                    </article>
                }
            </div>
        }
    </main>
</div>
@* ======================================================================================================================================================== *@


@section Scripts {
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({
            once: true,
            offset: 50,
            easing: 'ease-out-cubic'
        });
    </script>
}
@* ======================================================================================================================================================== *@