@{
    ViewData["Title"] = "";
}


@* ======================================================================================================================================================== *@
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Magazine/Index.css" />
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
<div class="magazine-wrapper">
    <header class="magazine-header">
        <div class="header-bg-text">ISSUE</div>
        <div class="header-content">
            <div class="header-badge animate-journal j-delay-1">
                <span class="line"></span>
                <span class="text">Ấn phẩm tập san</span>
                <span class="line"></span>
            </div>

            <h1 class="header-title animate-journal j-delay-2">
                Lặng. <span class="italic">Journal</span>
            </h1>

            <p class="header-quote animate-journal j-delay-3">
                "Định nghĩa về nghệ thuật sống qua lăng kính của sự tĩnh lặng và chiều sâu nội tại."
            </p>

            <div class="header-meta animate-journal j-delay-4">
                <span>Quarterly No. 1</span>
                <span class="header-meta dot"></span>
                <span>Summer 2024</span>
            </div>
        </div>
    </header>

    <main class="magazine-body">
        <div class="posts-grid">

            <a href="#" class="post-card" data-aos="fade-up" data-aos-delay="0">
                <div class="post-image-container">
                    <span class="post-category-tag">CHỮA LÀNH</span>
                    <img src="~/images/logo_website.png" class="post-image" alt="Nghệ thuật của sự chậm rãi" />
                </div>
                <div class="post-card-meta">
                    <span>02.06.2026</span>
                    <span>•</span>
                    <span>302 LƯỢT XEM</span>
                </div>
                <h3 class="post-card-title">Nghệ thuật của sự chậm rãi</h3>
                <p class="post-card-excerpt">
                    Trong một thế giới luôn hối hả, sự chậm rãi đôi khi bị coi là yếu đuối. Nhưng thực tế, chậm lại là cách duy nhất để chúng ta nhìn nhận rõ bản chất...
                </p>
                <div class="post-card-action">ĐỌC THÊM</div>
            </a>

            <a href="#" class="post-card" data-aos="fade-up" data-aos-delay="150">
                <div class="post-image-container">
                    <span class="post-category-tag">TÂM SỰ</span>
                    <img src="~/images/logo_website.png" class="post-image" alt="Tiếng vang trong tĩnh lặng" />
                </div>
                <div class="post-card-meta">
                    <span>08.06.2026</span>
                    <span>•</span>
                    <span>421 LƯỢT XEM</span>
                </div>
                <h3 class="post-card-title">Tiếng vang trong tĩnh lặng</h3>
                <p class="post-card-excerpt">
                    Có những điều chỉ có thể nghe thấy khi ta hoàn toàn im lặng. Im lặng không phải là sự vắng mặt của âm thanh, mà là trạng thái đón nhận trọn vẹn nhất...
                </p>
                <div class="post-card-action">ĐỌC THÊM</div>
            </a>

            <a href="#" class="post-card" data-aos="fade-up" data-aos-delay="300">
                <div class="post-image-container">
                    <span class="post-category-tag">KÝ ỨC</span>
                    <img src="~/images/logo_website.png" class="post-image" alt="Ký ức về những ngày nắng cũ" />
                </div>
                <div class="post-card-meta">
                    <span>18.05.2026</span>
                    <span>•</span>
                    <span>719 LƯỢT XEM</span>
                </div>
                <h3 class="post-card-title">Ký ức về những ngày nắng cũ</h3>
                <p class="post-card-excerpt">
                    Hoài niệm là một phần của tâm hồn. Những ngày nắng cũ mang theo mùi hương của sách mới, vị ngọt của tách trà chiều gieo vào lòng ta những bình lặng lạ kỳ...
                </p>
                <div class="post-card-action">ĐỌC THÊM</div>
            </a>

            <a href="#" class="post-card" data-aos="fade-up" data-aos-delay="0">
                <div class="post-image-container">
                    <span class="post-category-tag">TRIẾT LÝ</span>
                    <img src="~/images/logo_website.png" class="post-image" alt="Vết rêu phong trên thềm cũ" />
                </div>
                <div class="post-card-meta">
                    <span>04.06.2026</span>
                    <span>•</span>
                    <span>745 LƯỢT XEM</span>
                </div>
                <h3 class="post-card-title">Vết rêu phong trên thềm cũ</h3>
                <p class="post-card-excerpt">
                    Thời gian không xóa nhòa mọi thứ, nó chỉ phủ lên một lớp rêu xanh. Những mảng xanh li ti bám trên gạch đá kể câu chuyện về sự trường tồn thầm lặng...
                </p>
                <div class="post-card-action">ĐỌC THÊM</div>
            </a>

            <a href="#" class="post-card" data-aos="fade-up" data-aos-delay="150">
                <div class="post-image-container">
                    <span class="post-category-tag">TỰ NHIÊN</span>
                    <img src="~/images/logo_website.png" class="post-image" alt="Bản giao hưởng của đại ngàn" />
                </div>
                <div class="post-card-meta">
                    <span>24.05.2026</span>
                    <span>•</span>
                    <span>291 LƯỢT XEM</span>
                </div>
                <h3 class="post-card-title">Bản giao hưởng của đại ngàn</h3>
                <p class="post-card-excerpt">
                    Rừng sâu không bao giờ tĩnh mịch hoàn toàn. Đó là một bản giao hưởng phức tạp của hàng triệu sinh linh đang thở, đang chuyển động nhịp nhàng...
                </p>
                <div class="post-card-action">ĐỌC THÊM</div>
            </a>

        </div>
    </main>
</div>
@* ======================================================================================================================================================== *@


@* ======================================================================================================================================================== *@
@section Scripts {
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
    once: true,
    offset: 40,
    duration: 1000,
    easing: 'ease-out-cubic'
    });
</script>
}
@* ======================================================================================================================================================== *@