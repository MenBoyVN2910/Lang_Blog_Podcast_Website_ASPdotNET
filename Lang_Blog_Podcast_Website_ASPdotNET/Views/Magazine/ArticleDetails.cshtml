@model Lang_Blog_Podcast_Website_ASPdotNET.Models.MagazineArticle

@{
    ViewData["Title"] = Model.Title;
}

<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
<link rel="stylesheet" href="~/css/Magazine/Index.css" asp-append-version="true" />

<style>
    /* Styling dành riêng cho trang đọc bài Tạp chí */
    .article-header {
        position: relative;
        height: 80vh;
        width: 100%;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #111;
        color: #fff;
    }
    
    .article-header-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: url('@Model.ImagePath');
        background-size: cover;
        background-position: center;
        filter: grayscale(100%) brightness(40%);
        z-index: 1;
    }
    
    .article-header-content {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 0 20px;
        max-width: 1000px;
    }

    .article-category {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 12px;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin-bottom: 20px;
        color: #ddd;
    }

    .article-title {
        font-family: var(--font-serif-header);
        font-size: 4vw;
        line-height: 1.2;
        margin-bottom: 30px;
    }

    .article-meta {
        font-family: var(--font-sans);
        font-size: 14px;
        color: #aaa;
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .article-body {
        max-width: 800px;
        margin: -80px auto 100px auto;
        background: #fff;
        padding: 60px;
        position: relative;
        z-index: 10;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        font-family: var(--font-serif-body);
        font-size: 18px;
        line-height: 2;
        color: #222;
    }

    .article-body p {
        margin-bottom: 25px;
    }

    /* Định dạng Dropcap cho chữ cái đầu tiên của bài viết */
    .article-body > p:first-of-type::first-letter {
        font-size: 80px;
        float: left;
        line-height: 0.8;
        padding-right: 15px;
        padding-top: 5px;
        font-family: var(--font-serif-header);
        color: #111;
    }

    /* Các thành phần typography bên trong */
    .article-body h2, .article-body h3 {
        font-family: var(--font-sans);
        font-weight: 800;
        margin-top: 40px;
        margin-bottom: 20px;
        font-size: 24px;
    }

    .article-body blockquote {
        border-left: 5px solid #111;
        padding-left: 30px;
        margin: 40px 0;
        font-style: italic;
        font-size: 24px;
        color: #555;
    }

    .article-body img {
        max-width: 100%;
        height: auto;
        margin: 30px 0;
        filter: grayscale(100%);
    }
</style>

<div class="lang-magazine-avant-container" style="background-color: #f9f9f9; padding-bottom: 50px;">
    
    <div class="article-header" data-aos="fade-in">
        <div class="article-header-bg"></div>
        <div class="article-header-content">
            <div class="article-category" data-aos="fade-up" data-aos-delay="200">
                LẶNG. MAGAZINE / @(Model.Category?.Name ?? "Tạp Chí")
            </div>
            <h1 class="article-title" data-aos="fade-up" data-aos-delay="400">@Model.Title</h1>
            <div class="article-meta" data-aos="fade-up" data-aos-delay="600">
                <span><i class="fa-regular fa-clock"></i> @Model.CreatedAt.ToString("dd MMMM, yyyy")</span>
                <span><i class="fa-solid fa-hashtag"></i> Thuộc Ấn Phẩm: @(Model.Issue?.IssueNumber ?? "N/A")</span>
                <span><i class="fa-regular fa-eye"></i> @Model.ViewCount lượt đọc</span>
            </div>
        </div>
    </div>

    <main class="article-body" data-aos="fade-up" data-aos-delay="800">
        @Html.Raw(Model.Content)

        <div style="margin-top: 80px; border-top: 1px solid #ddd; padding-top: 40px; text-align: center;">
            <a href="/Magazine/IssueDetails/@Model.IssueId" class="btn outline" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 2px; padding: 12px 30px; text-decoration: none; color: #111;">
                &larr; TRỞ VỀ ẤN PHẨM @(Model.Issue?.IssueNumber)
            </a>
        </div>
    </main>
</div>

@section Scripts {
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({
            once: true,
            offset: 50,
            easing: 'ease-out-cubic',
            duration: 1200
        });
    </script>
}
