@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}



@* ============================================================================================================================== *@
@* Nhúng các font chữ và biểu tượng icon từ bên ngoài *@
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> <!-- Tạo kết nối sớm đến Google Fonts để tăng tốc độ tải font. -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="~/css/Manage/Register.css" asp-append-version="true" />
@* ============================================================================================================================== *@



@* ============================================================================================================================== *@
<div class="auth-container">
    @* Phần trang trí bên trái *@
    <div class="auth-left">
        <div class="bg-join">JOIN</div>
        <div class="auth-left-content">
            <div class="subtitle-small">HỆ SINH THÁI TINH THẦN</div>
            <h1 class="main-title">
                TRỞ<br /> THÀNH<br />
                <i> MỘT<br /> PHẦN. </i>
            </h1>
            <p class="quote-text">
                "Chúng tôi tin rằng mỗi tâm hồn đều mang trong mình một bản nhạc riêng. Hãy cùng chúng tôi viết nên những giai điệu của sự tĩnh lặng."
            </p>
        </div>
    </div>

    @* Phần nội dung đăng ký bên phải *@
    <div class="auth-right">
        <div class="form-wrapper">
            <div class="form-header">
                <h1>BẮT ĐẦU HÀNH TRÌNH.</h1>
                <p>KIẾN TẠO KHÔNG GIAN CỦA RIÊNG BẠN</p>
            </div>

            @* Form đăng ký chính *@
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @* Hiển thị danh sách tổng hợp các thông báo lỗi kiểm thử từ máy chủ gửi về *@
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                @* Trường Tên người dùng *@
                <div class="custom-form-group">
                    <label asp-for="Input.FullName">Tên người dùng</label>
                    <div class="input-icon-wrapper">
                        <i class="fa-solid fa-user" style="font-size: 0.9em;"></i>
                        <input asp-for="Input.FullName" class="custom-input" autocomplete="username" aria-required="true" placeholder="Tên Của Lặnger Là Gì Nèe..." />
                    </div>
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>

                @* Trường Email *@
                <div class="custom-form-group">
                    <label asp-for="Input.Email">Địa chỉ Email</label>
                    <div class="input-icon-wrapper">
                        <i class="fa-regular fa-envelope"></i>
                        @* Thêm pattern kiểm tra đuôi định dạng email *@
                        <input asp-for="Input.Email"
                               class="custom-input"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="Email của Lặnger..."
                               pattern="^[a-zA-Z0-9._%+-]+@@(gmail\.com|outlook\.com)$"
                               title="Vui lòng nhập đúng định dạng email (ví dụ: @@gmail.com, @@outlook.com)" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                @* Trường Mật mã *@
                <div class="custom-form-group">
                    <label asp-for="Input.Password">Mật mã</label>
                    <div class="input-icon-wrapper">
                        <i class="fa-solid fa-lock" style="font-size: 0.9em;"></i>
                        <input asp-for="Input.Password" class="custom-input" autocomplete="new-password" aria-required="true" placeholder="********" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                @* Trường Xác nhận mật mã *@
                <div class="custom-form-group">
                    <label asp-for="Input.ConfirmPassword">Xác nhận mật mã</label>
                    <div class="input-icon-wrapper">
                        <i class="fa-solid fa-lock" style="font-size: 0.9em;"></i>
                        <input asp-for="Input.ConfirmPassword" class="custom-input" autocomplete="new-password" aria-required="true" placeholder="********" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn-submit">Đăng ký tài khoản</button>
            </form>

            <div class="divider">
                <span>Hoặc</span>
            </div>

            @* Xử lý đăng nhập bằng tài khoản liên kết (Google, v.v.) -- Chưa Được Triển Khai *@
            @{
                if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            if (provider.Name.ToLower() == "google")
                            {
                                <button type="submit" class="btn-google" name="provider" value="@provider.Name">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google Logo" />
                                    TIẾP TỤC VỚI GOOGLE
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn-google" name="provider" value="@provider.Name">
                                    <i class="fa-brands fa-@provider.Name.ToLower()"></i> TIẾP TỤC VỚI @provider.DisplayName.ToUpper()
                                </button>
                            }
                        }
                    </form>
                }
            }

            <div class="login-link">
                Đã có tài khoản? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">ĐĂNG NHẬP NGAY</a>
            </div>
        </div>
    </div>
</div>
@* ============================================================================================================================== *@


@* ============================================================================================================================== *@
@section Scripts {
    @* Chèn các script xác thực mặc định *@
    <partial name="_ValidationScriptsPartial" />
}
@* ============================================================================================================================== *@