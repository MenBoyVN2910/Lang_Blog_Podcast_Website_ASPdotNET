@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Xác minh mã khôi phục"; // Tiêu đề trang
}

<h1>@ViewData["Title"]</h1>
<hr />

@* Thông báo hướng dẫn về việc sử dụng mã khôi phục *@
<p>
    Bạn đã yêu cầu đăng nhập bằng mã khôi phục. Lần đăng nhập này sẽ không được ghi nhớ cho đến khi bạn cung cấp mã ứng dụng xác thực khi đăng nhập hoặc tắt 2FA và đăng nhập lại.
</p>

<div class="row">
    <div class="col-md-4">
        @* Form nhập mã khôi phục *@
        <form method="post">
            @* Hiển thị các lỗi xác thực (nếu có) *@
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            @* Ô nhập mã khôi phục *@
            <div class="form-floating mb-3">
                <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="RecoveryCode" />
                <label asp-for="Input.RecoveryCode" class="form-label"></label>
                <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
            </div>

            @* Nút gửi mã để xác thực đăng nhập *@
            <button type="submit" class="w-100 btn btn-lg btn-primary">Đăng nhập</button>
        </form>
    </div>
</div>

@section Scripts {
    @* Nhúng các script hỗ trợ xác thực phía client *@
    <partial name="_ValidationScriptsPartial" />
}