@* Trang: Index.cshtml (Hồ sơ cá nhân)
    Chức năng: Cho phép người dùng xem thông tin tài khoản, cập nhật số điện thoại và thay đổi ảnh đại diện.
*@

@page
@model IndexModel
@{
    // Thiết lập tiêu đề trang và chỉ mục trang đang hoạt động trong menu
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<style>
    .lang-form-wrapper {
        max-width: 550px;
    }

    .lang-form-group {
        margin-bottom: 2.5rem;
    }

        .lang-form-group .form-label {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--lang-muted);
            font-weight: 600;
            margin-bottom: 0.8rem;
            display: block;
        }

        .lang-form-group .form-control {
            width: 100%;
            padding: 10px 0;
            border: none;
            border-bottom: 1px solid #ccc;
            background: transparent;
            outline: none;
        }

            .lang-form-group .form-control:disabled {
                color: #B5AFA6;
                border-bottom-color: var(--lang-border) !important;
                cursor: not-allowed;
            }

    .text-danger {
        font-size: 0.8rem;
        margin-top: 0.5rem;
        display: block;
        color: #A34A3B;
    }

    /* CSS: Khung chứa ảnh đại diện hình tròn */
    .avatar-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        overflow: hidden;
        border: 1px solid var(--lang-border, #e5e5e5);
        background-color: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .avatar-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
        }

    .avatar-placeholder {
        color: #999;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
</style>

<div class="lang-form-wrapper">
    @* Thông báo kết quả thao tác (thành công/lỗi) *@
    <partial name="_StatusMessage" for="StatusMessage" />

    <h3 class="lang-page-title">Thông tin cơ bản</h3>
    <div class="lang-page-subtitle" style="margin-bottom: 3rem; color: var(--lang-muted); font-style: italic; font-family: 'Playfair Display', serif;">
        Cập nhật thông tin định danh của bạn tại hệ sinh thái Lặng.
    </div>

    @* Form cập nhật hồ sơ với enctype để hỗ trợ upload file *@
    <form id="profile-form" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        @* 1. VÙNG AVATAR: Hiển thị ảnh hiện tại hoặc placeholder *@
        <div class="lang-form-group" style="display: flex; align-items: center; gap: 20px;">
            <div class="avatar-preview">
                @if (Model.HasAvatar && ViewData["UserAvatar"] is byte[] avatarData)
                {
                    <img id="profilePicturePreview"
                         src="data:image/jpeg;base64,@Convert.ToBase64String(avatarData)"
                         style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 1px solid var(--lang-border);" />
                }
                else
                {
                    <div id="profilePicturePreview" style="width: 80px; height: 80px; border-radius: 50%; background-color: #f5f5f5; border: 1px solid var(--lang-border); display: flex; align-items: center; justify-content: center;">
                        <span style="color: #999; font-size: 11px; text-transform: uppercase;">Ảnh</span>
                    </div>
                }
            </div>
            <div>
                <label class="form-label">Ảnh đại diện</label>
                <input type="file" accept="image/*" asp-for="Input.ProfilePicture" class="form-control" style="border: none; padding: 0; background: transparent; font-size: 13px;" />
                <span style="font-size: 11px; color: var(--lang-muted); display: block; margin-top: 5px;">JPG, PNG. Tối đa 2MB.</span>
            </div>
        </div>

        @* 2. VÙNG USERNAME: Thông tin chỉ đọc *@
        <div class="lang-form-group">
            <label class="form-label">Tên tài khoản (Username)</label>
            <input asp-for="Username" class="form-control" placeholder="Chưa cấu hình..." disabled />
        </div>

        @* 3. VÙNG SỐ ĐIỆN THOẠI: Thông tin có thể thay đổi *@
        <div class="lang-form-group">
            <label class="form-label">Số điện thoại</label>
            <input asp-for="Input.PhoneNumber"
                   class="form-control"
                   placeholder="Nhập số điện thoại của bạn..."
                   pattern="^0(3|5|7|8|9)[0-9]{8}$"
                   title="Vui lòng nhập 10 chữ số bắt đầu bằng 03, 05, 07, 08 hoặc 09." />
            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
        </div>

        @* 4. NÚT SUBMIT: Lưu thay đổi *@
        <button id="update-profile-button" type="submit" class="btn btn-primary w-100" style="background: #111; color: white; border: none; padding: 12px; width: 100%; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">
            Lưu thay đổi
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Script giúp đổi ảnh preview ngay lập tức trên màn hình khi người dùng chọn file
        document.querySelector('input[type="file"]').addEventListener('change', function(e) {
            if (this.files && this.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var preview = document.getElementById('profilePicturePreview');
                    if(preview.tagName === 'IMG') {
                        preview.setAttribute('src', e.target.result);
                    } else {
                        // Nếu đang là thẻ div "Trống", tự chuyển thành thẻ img
                        var img = document.createElement('img');
                        img.id = 'profilePicturePreview';
                        img.src = e.target.result;
                        img.style = "width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 1px solid var(--lang-border);";
                        preview.parentNode.replaceChild(img, preview);
                    }
                }
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}