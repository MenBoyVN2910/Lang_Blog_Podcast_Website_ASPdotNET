@page
@model SetPasswordModel
@{
    // Thiết lập tiêu đề trang hiển thị trên trình duyệt
    ViewData["Title"] = "Thiết lập mật khẩu";
    // Đánh dấu trang hiện tại để làm nổi bật mục tương ứng trong menu điều hướng
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<style>
    /* CSS Wrapper bao bọc nội dung trang */
    .lang-form-wrapper {
        max-width: 600px;
    }

    /* CSS hiển thị khung cảnh báo/thông tin */
    .lang-alert-warning {
        padding: 2rem;
        border: 1px solid #E8D3CC;
        background-color: #FCF8F7;
        font-family: 'Playfair Display', serif;
        font-style: italic;
        color: #A34A3B;
        margin-bottom: 2.5rem;
    }

    /* CSS cho các thẻ định dạng phím/mã */
    .lang-kbd {
        background: #F2EFEA;
        padding: 0.3rem 0.6rem;
        border-radius: 0;
        font-family: monospace;
        color: #2A2623;
    }

    /* CSS cho danh sách các bước hướng dẫn */
    .lang-step-list {
        list-style: none;
        padding-left: 0;
    }

    .lang-step-item {
        margin-bottom: 3rem;
    }

    .lang-step-num {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        color: #A34A3B;
        margin-bottom: 1rem;
        display: block;
    }
</style>

<h3>Thiết lập mật khẩu</h3>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="lang-form-wrapper">
    <h3 class="lang-page-title">Thiết lập mật khẩu</h3>
    <p style="font-family: 'Playfair Display', serif; color: var(--lang-muted); margin-bottom: 2rem;">
        Bạn chưa có mật khẩu cục bộ. Hãy tạo mới để đăng nhập trực tiếp vào hệ sinh thái Lặng.
    </p>

    <form id="set-password-form" method="post">
        <div class="lang-form-group">
            <label class="form-label">Mật khẩu mới</label>
            <input asp-for="Input.NewPassword" class="form-control" placeholder="Mật khẩu của bạn..." />
        </div>
        <div class="lang-form-group">
            <label class="form-label">Xác nhận mật khẩu</label>
            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu..." />
        </div>
        <button type="submit" class="w-100 btn btn-primary">Lưu mật khẩu</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}