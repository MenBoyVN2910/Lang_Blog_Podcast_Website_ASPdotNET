@* Trang: ChangePassword.cshtml    Chức năng: Cung cấp giao diện cho phép người dùng thay đổi mật khẩu tài khoản hiện tại.*@

@page
@model ChangePasswordModel
@{
    // Thiết lập tiêu đề trang và chỉ mục trang đang hoạt động cho menu điều hướng
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<style>
    /* CSS: Định nghĩa kích thước khung chứa form */
    .lang-form-wrapper {
        max-width: 550px;
    }

    /* CSS: Định nghĩa khoảng cách giữa các nhóm trường nhập liệu */
    .lang-form-group {
        margin-bottom: 2.5rem;
    }

        /* CSS: Style cho nhãn của input (label) */
        .lang-form-group .form-label {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--lang-muted);
            font-weight: 600;
            margin-bottom: 0.8rem;
            display: block;
        }

    /* Cấu trúc bọc input để đặt nút con mắt định vị tuyệt đối */
    .password-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

        .password-input-wrapper .form-control {
            width: 100%;
            padding-right: 40px; /* Tránh text đè lên icon */
        }

    /* Nút con mắt ẩn hiện */
    .toggle-password-btn {
        position: absolute;
        right: 5px;
        background: none;
        border: none;
        color: var(--lang-muted, #8c867a);
        cursor: pointer;
        padding: 8px;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s ease, transform 0.1s ease;
    }

        .toggle-password-btn:hover {
            color: #1a1a1a;
        }

        .toggle-password-btn:active {
            transform: scale(0.9);
        }
</style>

<div class="lang-form-wrapper">
    @* Render partial view hiển thị thông báo trạng thái thành công hoặc thất bại *@
    <partial name="_StatusMessage" for="StatusMessage" />

    <h3 class="lang-page-title">Mật khẩu</h3>
    <div class="lang-page-subtitle" style="margin-bottom: 3rem; color: var(--lang-muted); font-style: italic; font-family: 'Playfair Display', serif;">
        Bảo vệ không gian riêng tư của bạn.
    </div>

    @* Form thay đổi mật khẩu *@
    <form id="change-password-form" method="post">
        @* Hiển thị danh sách các lỗi tổng quát của Model (nếu có) *@
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        @* Nhóm: Mật khẩu hiện tại *@
        <div class="lang-form-group">
            <label class="form-label">Mật khẩu hiện tại</label>
            <div class="password-input-wrapper">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu hiện tại..." />
                <button type="button" class="toggle-password-btn" tabIndex="-1" title="Hiển thị mật khẩu">
                    <i class="fa-regular fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
        </div>

        @* Nhóm: Mật khẩu mới *@
        <div class="lang-form-group">
            <label class="form-label">Mật khẩu mới</label>
            <div class="password-input-wrapper">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới..." />
                <button type="button" class="toggle-password-btn" tabIndex="-1" title="Hiển thị mật khẩu">
                    <i class="fa-regular fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        </div>

        @* Nhóm: Xác nhận mật khẩu mới *@
        <div class="lang-form-group">
            <label class="form-label">Xác nhận mật khẩu mới</label>
            <div class="password-input-wrapper">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Xác nhận lại mật khẩu mới..." />
                <button type="button" class="toggle-password-btn" tabIndex="-1" title="Hiển thị mật khẩu">
                    <i class="fa-regular fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        @* Nút gửi yêu cầu cập nhật *@
        <button type="submit" class="w-100 btn btn-primary" style="background: #111; color: white; border: none; padding: 12px; width: 100%; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">
            Cập nhật mật khẩu
        </button>
    </form>
</div>

@section Scripts {
    @* Nạp các đoạn script xác thực dữ liệu phía client *@
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelectorAll('.toggle-password-btn').forEach(button => {
            button.addEventListener('click', function (e) {
                // Ngăn chặn form bị submit ngoài ý muốn khi click nhanh
                e.preventDefault();

                // Tìm thẻ input nằm cùng cấp trong cụm wrapper
                const input = this.parentElement.querySelector('input');
                const icon = this.querySelector('i');

                if (input.type === 'password') {
                    input.type = 'text';
                    // Thay đổi class để chuyển sang icon mắt gạch chéo
                    icon.className = 'fa-solid fa-eye-slash';
                    this.title = "Ẩn mật khẩu";
                } else {
                    input.type = 'password';
                    // Thay đổi class để chuyển về icon mắt mở
                    icon.className = 'fa-regular fa-eye';
                    this.title = "Hiển thị mật khẩu";
                }
            });
        });
    </script>
}